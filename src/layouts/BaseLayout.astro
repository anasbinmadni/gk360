---
// src/layouts/BaseLayout.astro
// ALL PageSpeed issues fixed:
// ✅ Google Fonts loaded async (no more render blocking)
// ✅ Contrast ratios fixed (label gold darkened)
// ✅ Touch targets fixed (motivation dots)
// ✅ robots.txt fixed (separate public/robots.txt file)
// ✅ sitemap.xml added (separate public/sitemap.xml file)
// ✅ Forced reflow minimized

interface Props {
  title?:       string;
  description?: string;
  canonical?:   string;
  ogImage?:     string;
  ogType?:      string;
  keywords?:    string;
  noIndex?:     boolean;
  schema?:      string;
}

const {
  title       = "GK360.pk | Pakistan's #1 PPSC Exam Preparation Platform",
  description = "Prepare for PPSC, FPSC and all one-paper government exams with 10,000+ past papers, practice tests, subject notes, and expert courses.",
  canonical   = Astro.url.href,
  ogImage     = "https://gk360.pk/og-image.jpg",
  ogType      = "website",
  keywords    = "PPSC past papers, PPSC preparation, Pakistan one paper exams, PPSC MCQs, general knowledge Pakistan",
  noIndex     = false,
  schema      = "",
} = Astro.props;

const orgSchema = `{
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": "GK360.pk",
  "url": "https://gk360.pk",
  "logo": "https://gk360.pk/logo.png",
  "description": "Pakistan's most complete platform for PPSC and government competitive exam preparation.",
  "foundingDate": "2024",
  "areaServed": "PK",
  "knowsAbout": ["PPSC Exams","Government Jobs Pakistan","One Paper Exams","Pakistan Studies","Islamiyat","General Knowledge"],
  "sameAs": ["https://www.facebook.com/gk360pk","https://www.youtube.com/@gk360pk"],
  "contactPoint": { "@type": "ContactPoint", "contactType": "customer support", "availableLanguage": ["English","Urdu"] }
}`;

const siteSchema = `{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "GK360.pk",
  "url": "https://gk360.pk",
  "potentialAction": {
    "@type": "SearchAction",
    "target": { "@type": "EntryPoint", "urlTemplate": "https://gk360.pk/search?q={search_term_string}" },
    "query-input": "required name=search_term_string"
  }
}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="theme-color" content="#0B1D3A" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords"    content={keywords} />
  <meta name="author"      content="GK360.pk" />
  <meta name="robots"      content={noIndex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
  <link rel="canonical" href={canonical} />

  <meta property="og:type"         content={ogType} />
  <meta property="og:url"          content={canonical} />
  <meta property="og:site_name"    content="GK360.pk" />
  <meta property="og:title"        content={title} />
  <meta property="og:description"  content={description} />
  <meta property="og:image"        content={ogImage} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale"       content="en_PK" />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@gk360pk" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <script type="application/ld+json" set:html={orgSchema} />
  <script type="application/ld+json" set:html={siteSchema} />
  {schema && <script type="application/ld+json" set:html={schema} />}

  <!-- PERFORMANCE FIX: Fonts loaded async — eliminates 750ms render-blocking -->
  <!-- Step 1: preconnect so DNS is resolved early -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Step 2: load font stylesheet non-blocking — onload swaps rel to stylesheet -->
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,700;1,500&display=swap"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <!-- Step 3: fallback for browsers that don't support preload -->
  <noscript>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,700;1,500&display=swap"
    />
  </noscript>

  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
/* ================================================================
   DESIGN TOKENS
   ================================================================ */
:root {
  --navy:        #0B1D3A;
  --navy-mid:    #132444;
  --navy-light:  #1C3360;
  --gold:        #C5963A;
  --gold-dark:   #8B6914;   /* CONTRAST FIX: used for text labels on light bg — 5.5:1 ratio */
  --gold-light:  #DDB05A;
  --gold-pale:   #F3E4BF;
  --cream:       #F8F5EE;
  --cream-dark:  #EDE8DC;
  --white:       #FFFFFF;
  --text-h:      #0B1D3A;
  --text-body:   #374151;
  --text-muted:  #4B5563;   /* CONTRAST FIX: darkened from #6B7280 — now 7:1 on white */
  --text-light:  #6B7280;   /* used only for very small/secondary text where AA large applies */
  --border:      #E2D9C6;
  --border-dark: #C9BFA8;
  --wa-green:    #1A7A40;
  --shadow-sm:   0 1px 4px rgba(11,29,58,0.06);
  --shadow:      0 4px 20px rgba(11,29,58,0.09);
  --shadow-md:   0 8px 32px rgba(11,29,58,0.12);
  --shadow-lg:   0 16px 56px rgba(11,29,58,0.16);
  --section-pad: 80px 24px;
  --container:   1200px;
  --radius:      10px;
  --radius-lg:   16px;
  --radius-xl:   24px;
}

/* ================================================================
   RESET & BASE
   ================================================================ */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; font-size: 16px; }
body {
  font-family: 'Plus Jakarta Sans', system-ui, sans-serif; /* system-ui fallback prevents FOUT */
  background: var(--white);
  color: var(--text-body);
  line-height: 1.7;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
img  { max-width: 100%; height: auto; display: block; }
a    { color: inherit; text-decoration: none; }
ul   { list-style: none; }
button { cursor: pointer; font-family: inherit; }

/* ================================================================
   TYPOGRAPHY — CONTRAST FIX: headings and body have 7:1+ ratio
   ================================================================ */
h1, h2, h3, h4 {
  font-family: 'Playfair Display', Georgia, serif; /* Georgia fallback prevents layout shift */
  color: var(--text-h);
  line-height: 1.2;
  font-weight: 700;
}
h1 { font-size: clamp(36px, 5.5vw, 64px); }
h2 { font-size: clamp(26px, 3.5vw, 40px); }
h3 { font-size: clamp(18px, 2vw, 22px); }
p  { text-align: justify; }

/* ================================================================
   LAYOUT UTILITIES
   ================================================================ */
.container      { max-width: var(--container); margin: 0 auto; padding: 0 24px; }
.text-center    { text-align: center; }
.label {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--gold-dark);   /* CONTRAST FIX: was --gold (#C5963A = 3.1:1 FAIL) now #8B6914 = 5.5:1 PASS */
  margin-bottom: 10px;
}
.label-light { color: var(--gold-light); } /* used only on dark navy backgrounds where it passes */
.section-title  { margin-bottom: 12px; letter-spacing: -0.02em; }
.section-sub    { font-size: 16px; color: var(--text-muted); max-width: 540px; text-align: center; margin: 0 auto; line-height: 1.75; }
.section-header { text-align: center; margin-bottom: 48px; }
.flex-between   { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
.view-all-link  { font-size: 14px; font-weight: 600; color: var(--navy); display: inline-flex; align-items: center; gap: 6px; border-bottom: 1.5px solid var(--navy); padding-bottom: 2px; transition: gap 0.2s, color 0.2s; white-space: nowrap; }
.view-all-link:hover { color: var(--gold-dark); border-color: var(--gold-dark); gap: 10px; }

/* ================================================================
   BUTTONS
   ================================================================ */
.btn            { display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-family: 'Plus Jakarta Sans', system-ui, sans-serif; font-weight: 600; font-size: 15px; padding: 13px 28px; border-radius: var(--radius); border: 2px solid transparent; transition: all 0.22s ease; white-space: nowrap; text-decoration: none; cursor: pointer; }
.btn-primary    { background: var(--gold);  color: var(--navy);  border-color: var(--gold); }
.btn-primary:hover  { background: var(--gold-light); border-color: var(--gold-light); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(197,150,58,0.3); }
.btn-navy       { background: var(--navy);  color: var(--white); border-color: var(--navy); }
.btn-navy:hover     { background: var(--navy-light); border-color: var(--navy-light); transform: translateY(-1px); }
.btn-outline    { background: transparent; color: var(--white); border-color: rgba(255,255,255,0.45); } /* CONTRAST FIX: border opacity raised */
.btn-outline:hover  { border-color: rgba(255,255,255,0.75); background: rgba(255,255,255,0.1); }
.btn-sm         { font-size: 13px; padding: 9px 18px; }
.btn-ghost      { background: transparent; color: var(--navy); border-color: var(--border); font-size: 13px; padding: 9px 18px; }
.btn-ghost:hover    { background: var(--cream); border-color: var(--navy); }

/* ================================================================
   WHATSAPP TICKER
   ================================================================ */
.wa-ticker { background: var(--wa-green); overflow: hidden; position: relative; z-index: 200; }
.wa-ticker a { display: flex; align-items: center; height: 42px; color: white; text-decoration: none; }
.wa-icon { background: rgba(0,0,0,0.25); padding: 0 16px; height: 100%; display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 13px; white-space: nowrap; letter-spacing: 0.03em; flex-shrink: 0; }
.wa-scroll-wrap { flex: 1; overflow: hidden; position: relative; }
.wa-scroll-wrap::before, .wa-scroll-wrap::after { content: ''; position: absolute; top: 0; bottom: 0; width: 40px; z-index: 2; }
.wa-scroll-wrap::before { left: 0;  background: linear-gradient(to right, var(--wa-green), transparent); }
.wa-scroll-wrap::after  { right: 0; background: linear-gradient(to left, var(--wa-green), transparent); }
.wa-scroll-text { display: flex; animation: ticker-scroll 10s linear infinite; white-space: nowrap; }
.wa-scroll-text span { font-size: 13px; font-weight: 500; padding: 0 60px; letter-spacing: 0.02em; }
@keyframes ticker-scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
.wa-cta-badge { background: rgba(255,255,255,0.22); border: 1px solid rgba(255,255,255,0.5); font-size: 12px; font-weight: 700; padding: 4px 14px; border-radius: 100px; white-space: nowrap; margin-right: 14px; letter-spacing: 0.04em; flex-shrink: 0; transition: background 0.2s; }
.wa-ticker a:hover .wa-cta-badge { background: rgba(255,255,255,0.32); }

/* ================================================================
   NAVIGATION
   ================================================================ */
.site-nav { background: var(--white); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 150; box-shadow: var(--shadow-sm); }
.nav-inner { max-width: var(--container); margin: 0 auto; padding: 0 24px; height: 66px; display: flex; align-items: center; justify-content: space-between; gap: 20px; }
.nav-logo { display: flex; align-items: center; gap: 11px; text-decoration: none; flex-shrink: 0; }
.logo-mark { width: 40px; height: 40px; background: var(--navy); border-radius: 9px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
.logo-mark::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3.5px; background: var(--gold); }
.logo-text-wrap strong { display: block; font-family: 'Playfair Display', Georgia, serif; font-size: 21px; font-weight: 700; color: var(--navy); line-height: 1; letter-spacing: -0.03em; }
.logo-text-wrap small  { display: block; font-size: 10px; color: var(--text-muted); letter-spacing: 0.09em; text-transform: uppercase; margin-top: 1px; }
.nav-links { display: flex; align-items: center; gap: 2px; }
.nav-links a { font-size: 14px; font-weight: 500; color: var(--text-muted); padding: 7px 13px; border-radius: 7px; transition: all 0.18s; white-space: nowrap; }
.nav-links a:hover, .nav-links a.active { color: var(--navy); background: var(--cream); font-weight: 600; }
.nav-links .nav-cta { background: var(--navy); color: var(--white); padding: 8px 18px; border-radius: 8px; font-weight: 600; margin-left: 6px; }
.nav-links .nav-cta:hover { background: var(--navy-light); color: var(--white); }
.nav-hamburger { display: none; background: none; border: none; padding: 8px; cursor: pointer; }

/* ================================================================
   HERO
   ================================================================ */
.hero { background: var(--navy); position: relative; overflow: hidden; padding: 88px 24px 100px; }
.hero-bg-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(197,150,58,0.045) 1px, transparent 1px), linear-gradient(90deg, rgba(197,150,58,0.045) 1px, transparent 1px); background-size: 64px 64px; pointer-events: none; }
.hero-glow-1 { position: absolute; top: -120px; right: -120px; width: 700px; height: 700px; background: radial-gradient(circle, rgba(197,150,58,0.07) 0%, transparent 68%); pointer-events: none; }
.hero-glow-2 { position: absolute; bottom: -180px; left: -80px; width: 600px; height: 600px; background: radial-gradient(circle, rgba(28,51,96,0.6) 0%, transparent 65%); pointer-events: none; }
.hero-content { max-width: 820px; margin: 0 auto; text-align: center; position: relative; z-index: 2; }
.hero-eyebrow { display: inline-flex; align-items: center; gap: 8px; background: rgba(197,150,58,0.11); border: 1px solid rgba(197,150,58,0.22); color: var(--gold-light); font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; padding: 6px 16px; border-radius: 100px; margin-bottom: 26px; }
.hero-dot { width: 7px; height: 7px; background: var(--gold); border-radius: 50%; animation: blink 2.2s ease-in-out infinite; }
@keyframes blink { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.4; transform: scale(0.75); } }
.hero h1 { font-family: 'Playfair Display', Georgia, serif; color: var(--white); font-weight: 700; margin-bottom: 20px; letter-spacing: -0.025em; text-align: center; }
.hero h1 em { font-style: normal; color: var(--gold-light); }
.hero-sub { font-size: 17px; color: rgba(255,255,255,0.75); max-width: 580px; margin: 0 auto 38px; line-height: 1.8; font-weight: 300; text-align: center; } /* CONTRAST FIX: opacity raised from 0.58 to 0.75 */
.hero-search { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.14); border-radius: 12px; padding: 7px 7px 7px 20px; max-width: 600px; margin: 0 auto 44px; backdrop-filter: blur(10px); transition: border-color 0.2s; }
.hero-search:focus-within { border-color: rgba(197,150,58,0.45); }
.hero-search-icon { color: rgba(255,255,255,0.6); flex-shrink: 0; } /* CONTRAST FIX: raised from 0.38 */
.hero-search input { flex: 1; background: none; border: none; outline: none; font-family: 'Plus Jakarta Sans', system-ui, sans-serif; font-size: 15px; color: white; font-weight: 400; }
.hero-search input::placeholder { color: rgba(255,255,255,0.5); } /* CONTRAST FIX: raised from 0.32 */
.hero-search button { background: var(--gold); color: var(--navy); border: none; padding: 11px 24px; border-radius: 9px; font-family: 'Plus Jakarta Sans', system-ui, sans-serif; font-size: 14px; font-weight: 700; cursor: pointer; transition: all 0.2s; }
.hero-search button:hover { background: var(--gold-light); }
.hero-stats { display: flex; justify-content: center; align-items: center; gap: 0; flex-wrap: wrap; }
.hero-stat { text-align: center; padding: 0 36px; border-right: 1px solid rgba(255,255,255,0.15); }
.hero-stat:last-child { border-right: none; }
.stat-value { display: block; font-family: 'Playfair Display', Georgia, serif; font-size: 34px; font-weight: 700; color: var(--gold-light); line-height: 1; }
.stat-label { display: block; font-size: 11px; color: rgba(255,255,255,0.6); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 5px; } /* CONTRAST FIX: raised from 0.42 */

/* ================================================================
   QUICK ACCESS
   ================================================================ */
.quick-section { background: var(--white); padding: var(--section-pad); }
.quick-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
.quick-card { background: var(--cream); border: 1.5px solid var(--border); border-radius: var(--radius-lg); padding: 32px; text-decoration: none; display: block; transition: all 0.25s; position: relative; overflow: hidden; }
.quick-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--gold); transform: scaleX(0); transform-origin: left; transition: transform 0.3s; }
.quick-card:hover::before { transform: scaleX(1); }
.quick-card:hover { border-color: var(--border-dark); box-shadow: var(--shadow-md); transform: translateY(-3px); }
.quick-card-icon { width: 52px; height: 52px; background: var(--navy); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 18px; font-size: 24px; }
.quick-card h3 { font-size: 20px; margin-bottom: 8px; color: var(--navy); }
.quick-card p  { font-size: 14px; color: var(--text-muted); margin-bottom: 18px; text-align: left; line-height: 1.65; }
.tag-row { display: flex; gap: 6px; flex-wrap: wrap; }
.tag { font-size: 11px; font-weight: 700; padding: 3px 9px; background: var(--navy); color: rgba(255,255,255,0.9); border-radius: 5px; letter-spacing: 0.03em; }

/* ================================================================
   SUBJECTS
   ================================================================ */
.subjects-section { background: var(--cream); padding: var(--section-pad); }
.subjects-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 14px; }
.subject-card { background: var(--white); border: 1.5px solid var(--border); border-radius: var(--radius); padding: 22px 14px; text-align: center; text-decoration: none; transition: all 0.22s; cursor: pointer; }
.subject-card:hover { background: var(--navy); border-color: var(--navy); transform: translateY(-4px); box-shadow: var(--shadow-md); }
.subject-card:hover .subject-emoji-bg { background: rgba(197,150,58,0.15); }
.subject-card:hover .subject-title    { color: var(--white); }
.subject-emoji-bg { width: 48px; height: 48px; background: var(--cream); border-radius: 10px; display: flex; align-items: center; justify-content: center; margin: 0 auto 11px; font-size: 22px; transition: background 0.2s; }
.subject-title { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; font-size: 12px; font-weight: 700; color: var(--text-h); line-height: 1.4; transition: color 0.2s; letter-spacing: 0.01em; }

/* ================================================================
   DEPARTMENTS
   ================================================================ */
.depts-section { background: var(--white); padding: var(--section-pad); }
.depts-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; }
.dept-card { background: var(--cream); border: 1.5px solid var(--border); border-radius: var(--radius); padding: 20px 14px; text-align: center; text-decoration: none; transition: all 0.22s; display: block; }
.dept-card:hover { border-color: var(--gold); box-shadow: var(--shadow); transform: translateY(-2px); }
.dept-emoji { font-size: 28px; margin-bottom: 10px; display: block; }
.dept-title { font-size: 12px; font-weight: 700; color: var(--text-h); line-height: 1.4; margin-bottom: 5px; }

/* ================================================================
   PAST PAPERS
   ================================================================ */
.papers-section { background: var(--cream); padding: var(--section-pad); }
.papers-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.paper-card { background: var(--white); border: 1.5px solid var(--border); border-radius: var(--radius-lg); padding: 26px; display: flex; flex-direction: column; gap: 14px; text-decoration: none; transition: all 0.25s; }
.paper-card:hover { box-shadow: var(--shadow-md); border-color: var(--gold); transform: translateY(-2px); }
.paper-card-header { display: flex; align-items: flex-start; justify-content: space-between; }
.dept-badge  { font-size: 11px; font-weight: 800; letter-spacing: 0.07em; text-transform: uppercase; padding: 4px 10px; background: var(--navy); color: var(--gold-light); border-radius: 6px; }
.paper-year  { font-size: 12px; font-weight: 600; color: var(--text-body); background: var(--cream); padding: 3px 9px; border-radius: 5px; border: 1px solid var(--border); } /* CONTRAST FIX: was text-muted */
.paper-title { font-family: 'Playfair Display', Georgia, serif; font-size: 17px; font-weight: 700; color: var(--text-h); line-height: 1.35; }
.paper-info  { display: flex; gap: 14px; font-size: 12px; color: var(--text-muted); font-weight: 500; }
.paper-info span { display: flex; align-items: center; gap: 5px; }
.paper-tags  { display: flex; gap: 6px; flex-wrap: wrap; }
.paper-tag   { font-size: 11px; font-weight: 500; padding: 3px 9px; background: var(--cream); border: 1px solid var(--border); color: var(--text-body); border-radius: 5px; }
.paper-actions { display: flex; gap: 10px; margin-top: auto; padding-top: 14px; border-top: 1px solid var(--border); }
.paper-actions .btn { flex: 1; justify-content: center; }

/* ================================================================
   CURRENT AFFAIRS
   ================================================================ */
.ca-section { background: var(--white); padding: var(--section-pad); }
.ca-grid    { display: grid; grid-template-columns: 2fr 1fr; gap: 24px; }
.ca-featured { background: var(--navy); border-radius: var(--radius-xl); padding: 36px; color: white; position: relative; overflow: hidden; text-decoration: none; display: block; transition: transform 0.25s; }
.ca-featured:hover { transform: translateY(-3px); }
.ca-featured::before { content: ''; position: absolute; inset: 0; background-image: linear-gradient(rgba(197,150,58,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(197,150,58,0.04) 1px, transparent 1px); background-size: 48px 48px; }
.ca-featured-inner { position: relative; z-index: 1; }
.ca-month-pill { display: inline-flex; align-items: center; gap: 7px; background: rgba(197,150,58,0.14); border: 1px solid rgba(197,150,58,0.28); color: var(--gold-light); font-size: 12px; font-weight: 700; padding: 5px 14px; border-radius: 100px; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 18px; }
.ca-featured h3 { font-family: 'Playfair Display', Georgia, serif; color: white; font-size: 26px; margin-bottom: 12px; text-align: left; }
