---
// src/layouts/BaseLayout.astro
// Ticker + Nav + Footer are now here — every page gets them automatically.

interface Props {
  title?:       string;
  description?: string;
  canonical?:   string;
  ogImage?:     string;
  ogType?:      string;
  keywords?:    string;
  noIndex?:     boolean;
  schema?:      string;
}

const {
  title       = "GK360.pk | Pakistan's #1 PPSC Exam Preparation Platform",
  description = "Prepare for PPSC, FPSC and all one-paper government exams with 10,000+ past papers, practice tests, subject notes, and expert courses.",
  canonical   = Astro.url.href,
  ogImage     = "https://gk360.pk/og-image.jpg",
  ogType      = "website",
  keywords    = "PPSC past papers, PPSC preparation, Pakistan one paper exams, PPSC MCQs, general knowledge Pakistan",
  noIndex     = false,
  schema      = "",
} = Astro.props;

// Active nav detection — marks the correct link as active on each page
const currentPath = Astro.url.pathname;
function isActive(path: string) {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
}

const orgSchema = `{
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": "GK360.pk",
  "url": "https://gk360.pk",
  "logo": "https://gk360.pk/logo.png",
  "description": "Pakistan's most complete platform for PPSC and government competitive exam preparation.",
  "foundingDate": "2024",
  "areaServed": "PK",
  "knowsAbout": ["PPSC Exams","Government Jobs Pakistan","One Paper Exams","Pakistan Studies","Islamiyat","General Knowledge"],
  "sameAs": ["https://www.facebook.com/gk360pk","https://www.youtube.com/@gk360pk"],
  "contactPoint": { "@type": "ContactPoint", "contactType": "customer support", "availableLanguage": ["English","Urdu"] }
}`;

const siteSchema = `{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "GK360.pk",
  "url": "https://gk360.pk",
  "potentialAction": {
    "@type": "SearchAction",
    "target": { "@type": "EntryPoint", "urlTemplate": "https://gk360.pk/search?q={search_term_string}" },
    "query-input": "required name=search_term_string"
  }
}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="theme-color" content="#0B1D3A" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords"    content={keywords} />
  <meta name="author"      content="GK360.pk" />
  <meta name="robots"      content={noIndex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type"         content={ogType} />
  <meta property="og:url"          content={canonical} />
  <meta property="og:site_name"    content="GK360.pk" />
  <meta property="og:title"        content={title} />
  <meta property="og:description"  content={description} />
  <meta property="og:image"        content={ogImage} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale"       content="en_PK" />
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@gk360pk" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />
  <script type="application/ld+json" set:html={orgSchema} />
  <script type="application/ld+json" set:html={siteSchema} />
  {schema && <script type="application/ld+json" set:html={schema} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style"
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,700;1,500&display=swap"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,700;1,500&display=swap"
    />
  </noscript>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
</head>

<body>

  <!-- ═══ WHATSAPP TICKER ══════════════════════════════════ -->
  <div class="wa-ticker" role="banner" aria-label="Job updates ticker">
    <a href="https://wa.me/channel/gk360pk" target="_blank" rel="noopener noreferrer nofollow">
      <div class="wa-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="white" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.1.546 4.07 1.5 5.78L0 24l6.375-1.5A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.886 0-3.653-.494-5.188-1.362L3 22l1.388-3.742A9.936 9.936 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
        </svg>
        <span>Job Alerts</span>
      </div>
      <div class="wa-scroll-wrap">
        <div class="wa-scroll-text">
          <span>🔥 900+ Open Government Positions Right Now &nbsp;·&nbsp; New PPSC Jobs Posted Daily &nbsp;·&nbsp; Police, Tehsildar, Finance, Education &amp; More &nbsp;·&nbsp; Stay Ahead of Every Notification &nbsp;·&nbsp; Don't Miss Your Dream Government Job &nbsp;·&nbsp; 🔥 900+ Open Government Positions Right Now &nbsp;·&nbsp; New PPSC Jobs Posted Daily &nbsp;·&nbsp; Police, Tehsildar, Finance, Education &amp; More &nbsp;·&nbsp; Stay Ahead of Every Notification &nbsp;·&nbsp; Don't Miss Your Dream Government Job &nbsp;·&nbsp;</span>
        </div>
      </div>
      <span class="wa-cta-badge">Join Channel →</span>
    </a>
  </div>

  <!-- ═══ NAVIGATION ════════════════════════════════════════ -->
  <nav class="site-nav" role="navigation" aria-label="Main navigation">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="GK360.pk Home">
        <div class="logo-mark">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="#C5963A" stroke-width="2"/>
            <path d="M12 6v6l4 2" stroke="white" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="logo-text-wrap">
          <strong>GK360.pk</strong>
          <small>PPSC Preparation Academy</small>
        </div>
      </a>

      <ul class="nav-links" role="menubar">
        <li role="none"><a href="/"               class={isActive('/')             ? 'active' : ''} role="menuitem">Home</a></li>
        <li role="none"><a href="/past-papers"    class={isActive('/past-papers')  ? 'active' : ''} role="menuitem">Past Papers</a></li>
        <li role="none"><a href="/subjects"       class={isActive('/subjects')     ? 'active' : ''} role="menuitem">Subjects</a></li>
        <li role="none"><a href="/current-affairs" class={isActive('/current-affairs') ? 'active' : ''} role="menuitem">Current Affairs</a></li>
        <li role="none"><a href="/english"        class={isActive('/english')      ? 'active' : ''} role="menuitem">English</a></li>
        <li role="none"><a href="/blog"           class={isActive('/blog')         ? 'active' : ''} role="menuitem">Blog</a></li>
        <li role="none"><a href="/quiz"           class={isActive('/quiz')         ? 'active' : ''} role="menuitem">Free Quiz</a></li>
        <li role="none"><a href="/course" class="nav-cta" role="menuitem">Join Course →</a></li>
      </ul>

      <button class="nav-hamburger" aria-label="Toggle mobile menu" aria-expanded="false" id="nav-hamburger">
        <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#0B1D3A" stroke-width="2">
          <path d="M3 12h18M3 6h18M3 18h18" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu drawer -->
    <div class="mobile-menu" id="mobile-menu" hidden>
      <ul>
        <li><a href="/"               class={isActive('/')                  ? 'active' : ''}>Home</a></li>
        <li><a href="/past-papers"    class={isActive('/past-papers')       ? 'active' : ''}>Past Papers</a></li>
        <li><a href="/subjects"       class={isActive('/subjects')          ? 'active' : ''}>Subjects</a></li>
        <li><a href="/current-affairs" class={isActive('/current-affairs')  ? 'active' : ''}>Current Affairs</a></li>
        <li><a href="/english"        class={isActive('/english')           ? 'active' : ''}>English</a></li>
        <li><a href="/blog"           class={isActive('/blog')              ? 'active' : ''}>Blog</a></li>
        <li><a href="/quiz"           class={isActive('/quiz')              ? 'active' : ''}>Free Quiz</a></li>
        <li><a href="/course" class="mobile-cta">Join Course →</a></li>
      </ul>
    </div>
  </nav>

  <!-- ═══ PAGE CONTENT ══════════════════════════════════════ -->
  <slot />

  <!-- ═══ FOOTER ═══════════════════════════════════════════ -->
  <footer role="contentinfo">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="nav-logo" aria-label="GK360.pk Home">
          <div class="logo-mark">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="10" stroke="#C5963A" stroke-width="2"/>
              <path d="M12 6v6l4 2" stroke="white" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="logo-text-wrap">
            <strong style="color:white;">GK360.pk</strong>
            <small style="color:rgba(255,255,255,0.7);">PPSC Preparation Academy</small>
          </div>
        </a>
        <p>Pakistan's most complete platform for PPSC and government competitive exam preparation. Free past papers, practice tests, and expert-led courses for all one-paper exams.</p>
        <div class="footer-social" aria-label="Social media links">
          <a class="social-link" href="https://facebook.com/gk360pk"  target="_blank" rel="noopener" aria-label="Facebook">📘</a>
          <a class="social-link" href="https://youtube.com/@gk360pk"  target="_blank" rel="noopener" aria-label="YouTube">📺</a>
          <a class="social-link" href="https://wa.me/channel/gk360pk" target="_blank" rel="noopener" aria-label="WhatsApp">💬</a>
          <a class="social-link" href="https://instagram.com/gk360pk" target="_blank" rel="noopener" aria-label="Instagram">📸</a>
        </div>
      </div>
      <div class="footer-col">
        <p class="footer-heading">Past Papers</p>
        <ul>
          <li><a href="/past-papers/year/2026">PPSC Papers 2026</a></li>
          <li><a href="/past-papers/year/2025">PPSC Papers 2025</a></li>
          <li><a href="/past-papers/department/police">Police Department</a></li>
          <li><a href="/past-papers/department/tehsildar">Tehsildar / Revenue</a></li>
          <li><a href="/past-papers/department/asf">Airport Security Force</a></li>
          <li><a href="/past-papers/department/finance">Finance Department</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <p class="footer-heading">Subjects</p>
        <ul>
          <li><a href="/subjects/general-knowledge">General Knowledge</a></li>
          <li><a href="/subjects/pakistan-studies">Pakistan Studies</a></li>
          <li><a href="/subjects/islamiyat">Islamiyat</a></li>
          <li><a href="/subjects/general-science">General Science</a></li>
          <li><a href="/subjects/english">English</a></li>
          <li><a href="/subjects/urdu">Urdu</a></li>
          <li><a href="/subjects/current-affairs">Current Affairs</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <p class="footer-heading">Quick Links</p>
        <ul>
          <li><a href="/course">Join Course</a></li>
          <li><a href="/quiz">Free Quiz</a></li>
          <li><a href="/current-affairs">Current Affairs</a></li>
          <li><a href="/english">English Corner</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <p class="footer-heading">Legal</p>
        <ul>
          <li><a href="/privacy">Privacy Policy</a></li>
          <li><a href="/terms">Terms of Use</a></li>
          <li><a href="/disclaimer">Disclaimer</a></li>
        </ul>
        <p class="footer-heading" style="margin-top:24px;">Partners</p>
        <ul>
          <li><a href="https://www.voxenglishacademy.com" target="_blank" rel="noopener">VoxEnglishAcademy</a></li>
        </ul>
      </div>
    </div>
    <hr class="footer-divider" />
    <div class="footer-bottom">
      <span>© 2026 GK360.pk — All rights reserved. Proudly serving Pakistan 🇵🇰</span>
      <div class="footer-made-by">
        <span>Made with</span>
        <span class="heart" aria-label="love">❤️</span>
        <span>by</span>
        <a href="https://www.abraajgrowthlabs.com" target="_blank" rel="noopener noreferrer">Abraaj Growth Labs</a>
      </div>
    </div>
  </footer>

  <!-- Mobile Nav Script -->
  <script>
    const hamburger = document.getElementById('nav-hamburger');
    const mobileMenu = document.getElementById('mobile-menu');
    if (hamburger && mobileMenu) {
      hamburger.addEventListener('click', () => {
        const isOpen = !mobileMenu.hidden;
        mobileMenu.hidden = isOpen;
        hamburger.setAttribute('aria-expanded', String(!isOpen));
      });
    }
  </script>

</body>
</html>

<style is:global>
/* ================================================================
   DESIGN TOKENS
   ================================================================ */
:root {
  --navy:        #0B1D3A;
  --navy-mid:    #132444;
  --navy-light:  #1C3360;
  --gold:        #C5963A;
  --gold-dark:   #8B6914;
  --gold-light:  #DDB05A;
  --gold-pale:   #F3E4BF;
  --cream:       #F8F5EE;
  --cream-dark:  #EDE8DC;
  --white:       #FFFFFF;
  --text-h:      #0B1D3A;
  --text-body:   #374151;
  --text-muted:  #4B5563;
  --text-light:  #6B7280;
  --border:      #E2D9C6;
  --border-dark: #C9BFA8;
  --wa-green:    #1A7A40;
  --shadow-sm:   0 1px 4px rgba(11,29,58,0.06);
  --shadow:      0 4px 20px rgba(11,29,58,0.09);
  --shadow-md:   0 8px 32px rgba(11,29,58,0.12);
  --shadow-lg:   0 16px 56px rgba(11,29,58,0.16);
  --section-pad: 80px 24px;
  --container:   1200px;
  --radius:      10px;
  --radius-lg:   16px;
  --radius-xl:   24px;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; font-size: 16px; }
body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; background: var(--white); color: var(--text-body); line-height: 1.7; overflow-x: hidden; -webkit-font-smoothing: antialiased; }
img  { max-width: 100%; height: auto; display: block; }
a    { color: inherit; text-decoration: none; }
ul   { list-style: none; }
button { cursor: pointer; font-family: inherit; }

h1, h2, h3, h4 { font-family: 'Playfair Display', Georgia, serif; color: var(--text-h); line-height: 1.2; font-weight: 700; }
h1 { font-size: clamp(36px, 5.5vw, 64px); }
h2 { font-size: clamp(26px, 3.5vw, 40px); }
h3 { font-size: clamp(18px, 2vw, 22px); }
p  { text-align: justify; }

.container      { max-width: var(--container); margin: 0 auto; padding: 0 24px; }
.label          { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold-dark); margin-bottom: 10px; }
.label-light    { color: rgba(197,150,58,0.85); }
.section-title  { margin-bottom: 12px; letter-spacing: -0.02em; }
.section-sub    { font-size: 16px; color: var(--text-muted); max-width: 540px; text-align: center; margin: 0 auto; line-height: 1.75; }
.section-header { text-align: center; margin-bottom: 48px; }
.flex-between   { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
.view-all-link  { font-size: 14px; font-weight: 600; color: var(--navy); display: inline-flex; align-items: center; gap: 6px; border-bottom: 1.5px solid var(--navy); padding-bottom: 2px; transition: gap 0.2s, color 0.2s; white-space: nowrap; }
.view-all-link:hover { color: var(--gold-dark); border-color: var(--gold-dark); gap: 10px; }

.btn            { display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-family: 'Plus Jakarta Sans', system-ui, sans-serif; font-weight: 600; font-size: 15px; padding: 13px 28px; border-radius: var(--radius); border: 2px solid transparent; transition: all 0.22s ease; white-space: nowrap; text-decoration: none; cursor: pointer; }
.btn-primary    { background: var(--gold);  color: var(--navy);  border-color: var(--gold); }
.btn-primary:hover  { background: var(--gold-light); border-color: var(--gold-light); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(197,150,58,0.3); }
.btn-navy       { background: var(--navy);  color: var(--white); border-color: var(--navy); }
.btn-navy:hover     { background: var(--navy-light); border-color: var(--navy-light); transform: translateY(-1px); }
.btn-outline    { background: transparent; color: var(--white); border-color: rgba(255,255,255,0.45); }
.btn-outline:hover  { border-color: rgba(255,255,255,0.75); background: rgba(255,255,255,0.1); }
.btn-sm         { font-size: 13px; padding: 9px 18px; }
.btn-ghost      { background: transparent; color: var(--navy); border-color: var(--border); font-size: 13px; padding: 9px 18px; }
.btn-ghost:hover    { background: var(--cream); border-color: var(--navy); }

/* ── WHATSAPP TICKER ── */
.wa-ticker { background: var(--wa-green); overflow: hidden; position: relative; z-index: 200; }
.wa-ticker a { display: flex; align-items: center; height: 42px; color: white; text-decoration: none; }
.wa-icon { background: rgba(0,0,0,0.25); padding: 0 16px; height: 100%; display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 13px; white-space: nowrap; flex-shrink: 0; }
.wa-scroll-wrap { flex: 1; overflow: hidden; position: relative; }
.wa-scroll-wrap::before { left: 0;  content:''; position:absolute; top:0; bottom:0; width:40px; z-index:2; background: linear-gradient(to right, var(--wa-green), transparent); }
.wa-scroll-wrap::after  { right: 0; content:''; position:absolute; top:0; bottom:0; width:40px; z-index:2; background: linear-gradient(to left, var(--wa-green), transparent); }
.wa-scroll-text { display: flex; animation: ticker-scroll 10s linear infinite; white-space: nowrap; }
.wa-scroll-text span { font-size: 13px; font-weight: 500; padding: 0 60px; }
@keyframes ticker-scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
.wa-cta-badge { background: rgba(255,255,255,0.22); border: 1px solid rgba(255,255,255,0.5); font-size: 12px; font-weight: 700; padding: 4px 14px; border-radius: 100px; white-space: nowrap; margin-right: 14px; flex-shrink: 0; transition: background 0.2s; }
.wa-ticker a:hover .wa-cta-badge { background: rgba(255,255,255,0.32); }

/* ── NAVIGATION ── */
.site-nav { background: var(--white); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 150; box-shadow: var(--shadow-sm); }
.nav-inner { max-width: var(--container); margin: 0 auto; padding: 0 24px; height: 66px; display: flex; align-items: center; justify-content: space-between; gap: 20px; }
.nav-logo { display: flex; align-items: center; gap: 11px; text-decoration: none; flex-shrink: 0; }
.logo-mark { width: 40px; height: 40px; background: var(--navy); border-radius: 9px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
.logo-mark::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3.5px; background: var(--gold); }
.logo-text-wrap strong { display: block; font-family: 'Playfair Display', Georgia, serif; font-size: 21px; font-weight: 700; color: var(--navy); line-height: 1; letter-spacing: -0.03em; }
.logo-text-wrap small  { display: block; font-size: 10px; color: var(--text-muted); letter-spacing: 0.09em; text-transform: uppercase; margin-top: 1px; }
.nav-links { display: flex; align-items: center; gap: 2px; }
.nav-links a { font-size: 14px; font-weight: 500; color: var(--text-muted); padding: 7px 13px; border-radius: 7px; transition: all 0.18s; white-space: nowrap; }
.nav-links a:hover, .nav-links a.active { color: var(--navy); background: var(--cream); font-weight: 600; }
.nav-links .nav-cta { background: var(--navy); color: var(--white) !important; padding: 8px 18px; border-radius: 8px; font-weight: 600; margin-left: 6px; }
.nav-links .nav-cta:hover { background: var(--navy-light); }
.nav-hamburger { display: none; background: none; border: none; padding: 8px; cursor: pointer; }
.mobile-menu { background: var(--white); border-top: 1px solid var(--border); padding: 12px 24px 20px; box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
.mobile-menu ul { display: flex; flex-direction: column; gap: 2px; }
.mobile-menu a { display: block; font-size: 15px; font-weight: 500; color: var(--text-muted); padding: 10px 14px; border-radius: 8px; transition: all 0.18s; }
.mobile-menu a:hover, .mobile-menu a.active { color: var(--navy); background: var(--cream); font-weight: 600; }
.mobile-menu .mobile-cta { background: var(--navy); color: white !important; font-weight: 700; text-align: center; margin-top: 8px; }

/* ── HERO ── */
