  It provides: <html>, <head>, all meta tags, CSS, fonts, schema.
  You pass in the values that change per page.
  Everything inside this tag becomes the <body> content.
-->
<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={faqSchema}
