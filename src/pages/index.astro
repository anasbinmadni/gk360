---
/*
  ╔══════════════════════════════════════════════════════════════════╗
  ║  src/pages/index.astro                                           ║
  ║                                                                  ║
  ║  THIS IS THE HOMEPAGE.                                           ║
  ║  It only contains the page CONTENT (body).                       ║
  ║  The <head>, fonts, CSS, and schema are all                      ║
  ║  handled by BaseLayout.astro automatically.                      ║
  ╚══════════════════════════════════════════════════════════════════╝
*/

import BaseLayout from '../layouts/BaseLayout.astro';

// ── PAGE-SPECIFIC SEO VALUES ───────────────────────────────────────
// These are the ONLY SEO things you manage per page.
// Everything else (canonical, og:image, schema, fonts) is automatic.

const title       = "GK360.pk | Pakistan's #1 PPSC Exam Preparation Platform — 10,000+ Past Papers";
const description = "Prepare for PPSC, FPSC and all one-paper government exams with 10,000+ past papers, practice tests, subject notes, and expert courses. Free resources for Police, Tehsildar, ASF & 20+ departments.";
const keywords    = "PPSC past papers 2026, PPSC preparation, PPSC police past papers, tehsildar past papers, ASF past papers, Pakistan one paper exams, PPSC MCQs, general knowledge Pakistan";

// ── HOMEPAGE-SPECIFIC SCHEMA (FAQ) ───────────────────────────────
// This gets passed to BaseLayout and injected into <head> automatically.
// Only the homepage has this FAQ schema.
// Other pages will pass different schema (Article, BreadcrumbList, etc.)

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is PPSC one paper exam pattern?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "PPSC one paper exam consists of 100 MCQ questions from General Knowledge, Pakistan Studies, Islamiyat, General Science, English, Urdu, and Current Affairs. Time allowed is 90 minutes."
      }
    },
    {
      "@type": "Question",
      "name": "Where can I find PPSC past papers for free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GK360.pk provides 10,000+ PPSC past papers completely free, organized by year, department, and subject. No registration required."
      }
    },
    {
      "@type": "Question",
      "name": "How to prepare for PPSC police exam?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Practice past papers from the police department section, focus on General Knowledge, Islamiyat, Pakistan Studies, and English, and take timed practice tests on GK360.pk."
      }
    }
  ]
};
---

<!--
  BaseLayout wraps everything.
  It provides: <html>, <head>, all meta tags, CSS, fonts, schema.
  You pass in the values that change per page.
  Everything inside this tag becomes the <body> content.
-->
<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={faqSchema}
>

