  <script>
    // ── PAPERS DATA ──────────────────────────────────────────────
    // ADD NEW PAPERS HERE — departments + homepage auto-update.
    // In Astro Phase 2, this will be replaced by:
    //   const papers = await getCollection('past-papers');
    const papersData = [
      { id:"ppsc-asi-2026-01",       title:"PPSC Assistant Sub Inspector (ASI) 2026",       year:2026, dept:"Punjab Police",            deptSlug:"police",           mcqs:100, minutes:90, solved:true, subjects:["GK","Pak Studies","Islamiyat","English"] },
      { id:"ppsc-si-2025-01",        title:"PPSC Sub Inspector (SI) Punjab Police 2025",     year:2025, dept:"Punjab Police",            deptSlug:"police",           mcqs:100, minutes:90, solved:true, subjects:["GK","Urdu","Islamiyat","Current Affairs"] },
      { id:"ppsc-tehsildar-2026-01", title:"PPSC Tehsildar / Naib Tehsildar 2026",           year:2026, dept:"Revenue Department",       deptSlug:"tehsildar",        mcqs:100, minutes:90, solved:true, subjects:["GK","Islamiyat","Pak Studies","Maps"] },
      { id:"ppsc-asf-corporal-2025", title:"PPSC ASF Corporal 2025",                         year:2025, dept:"Airport Security Force",   deptSlug:"asf",              mcqs:100, minutes:90, solved:true, subjects:["GK","English","General Science","Islamiyat"] },
      { id:"ppsc-finance-2025",      title:"PPSC Finance Department Accountant 2025",        year:2025, dept:"Finance Department",       deptSlug:"finance",          mcqs:100, minutes:90, solved:true, subjects:["GK","Pak Studies","Urdu","English"] },
      { id:"ppsc-education-2025",    title:"PPSC Education Dept — ESE Teacher 2025",         year:2025, dept:"Education Department",     deptSlug:"education",        mcqs:100, minutes:90, solved:true, subjects:["GK","Islamiyat","English","Urdu"] },
      { id:"ppsc-health-2025",       title:"PPSC Health Dept — LHW Supervisor 2025",         year:2025, dept:"Health Department",        deptSlug:"health",           mcqs:100, minutes:90, solved:true, subjects:["GK","General Science","Islamiyat"] },
      { id:"ppsc-pfa-2025",          title:"PPSC Punjab Food Authority — Inspector 2025",    year:2025, dept:"Punjab Food Authority",    deptSlug:"pfa",              mcqs:100, minutes:90, solved:true, subjects:["GK","General Science","Pak Studies"] },
      { id:"ppsc-irrigation-2025",   title:"PPSC Irrigation Dept — Canal Patwari 2025",      year:2025, dept:"Irrigation Department",    deptSlug:"irrigation",       mcqs:100, minutes:90, solved:true, subjects:["GK","Urdu","Islamiyat","Maps"] },
      { id:"ppsc-excise-2025",       title:"PPSC Excise & Taxation Officer 2025",            year:2025, dept:"Excise & Taxation",        deptSlug:"excise-taxation",  mcqs:100, minutes:90, solved:true, subjects:["GK","Pak Studies","English","Current Affairs"] },
      { id:"ppsc-ace-2024",          title:"PPSC Anti-Corruption Inspector 2024",            year:2024, dept:"Anti-Corruption (ACE)",    deptSlug:"ace",              mcqs:100, minutes:90, solved:true, subjects:["GK","Islamiyat","Pak Studies","English"] },
      { id:"ppsc-lgcd-2024",         title:"PPSC Local Govt — Municipal Inspector 2024",     year:2024, dept:"Local Government",         deptSlug:"local-government", mcqs:100, minutes:90, solved:true, subjects:["GK","Pak Studies","Urdu","Islamiyat"] },
      { id:"ppsc-agriculture-2024",  title:"PPSC Agriculture Dept — Field Assistant 2024",   year:2024, dept:"Agriculture Department",   deptSlug:"agriculture",      mcqs:100, minutes:90, solved:true, subjects:["GK","General Science","Islamiyat"] },
      { id:"ppsc-prison-2024",       title:"PPSC Prison Department — Warder 2024",           year:2024, dept:"Prison Department",        deptSlug:"prison",           mcqs:100, minutes:90, solved:true, subjects:["GK","Islamiyat","Urdu","Pak Studies"] },
      { id:"ppsc-labour-2024",       title:"PPSC Labour & HR — Labour Inspector 2024",       year:2024, dept:"Labour & Human Resource",  deptSlug:"labour",           mcqs:100, minutes:90, solved:true, subjects:["GK","English","Islamiyat","Pak Studies"] },
    ];

    // ── DEPT ICONS & DISPLAY NAMES ───────────────────────────────
    const deptMeta = {
      "police":               { icon:"👮",  name:"Punjab Police" },
      "tehsildar":            { icon:"🏛️",  name:"Revenue / Tehsildar" },
      "asf":                  { icon:"✈️",  name:"Airport Security Force" },
      "finance":              { icon:"💼",  name:"Finance Department" },
      "education":            { icon:"📚",  name:"Education Department" },
      "health":               { icon:"🏥",  name:"Health Department" },
      "pfa":                  { icon:"🍽️",  name:"Punjab Food Authority" },
      "irrigation":           { icon:"💧",  name:"Irrigation Department" },
      "excise-taxation":      { icon:"🧾",  name:"Excise & Taxation" },
      "ace":                  { icon:"⚖️",  name:"Anti-Corruption (ACE)" },
      "local-government":     { icon:"🏙️",  name:"Local Government" },
      "agriculture":          { icon:"🌾",  name:"Agriculture Department" },
      "prison":               { icon:"🔒",  name:"Prison Department" },
      "labour":               { icon:"🔧",  name:"Labour & HR Dept" },
      "social-welfare":       { icon:"🤝",  name:"Social Welfare" },
      "forest":               { icon:"🌳",  name:"Forests & Wildlife" },
      "planning-development": { icon:"📊",  name:"Planning & Development" },
      "auqaf":                { icon:"🕌",  name:"Auqaf Department" },
      "transport":            { icon:"🚌",  name:"Transport Department" },
      "home":                 { icon:"🛡️",  name:"Home Department" },
      "pera": { icon: "⚖️", name: "PERA — Enforcement Authority" },
    };

    function renderDepartments() {
      const map = {};
      papersData.forEach(p => {
        if (!map[p.deptSlug]) {
          const m = deptMeta[p.deptSlug] || { icon:"🏢", name:p.dept };
          map[p.deptSlug] = { slug:p.deptSlug, ...m, count:0 };
        }
        map[p.deptSlug].count++;
      });
      const grid = document.getElementById('depts-grid');
      if (!grid) return;
      grid.innerHTML = Object.values(map)
        .sort((a,b) => b.count - a.count)
        .map(d => `
          <a href="/past-papers/department/${d.slug}" class="dept-card" role="listitem">
            <span class="dept-emoji" aria-hidden="true">${d.icon}</span>
            <div class="dept-title">${d.name}</div>
          </a>`)
        .join('');
    }

    function renderLatestPapers() {
      const grid = document.getElementById('papers-grid');
      if (!grid) return;
      grid.innerHTML = [...papersData]
        .sort((a,b) => b.year - a.year)
        .slice(0, 6)
        .map(p => `
          <article class="paper-card" role="listitem">
            <div class="paper-card-header">
              <span class="dept-badge">${p.dept.split(' ')[0]}</span>
              <span class="paper-year">${p.year}</span>
            </div>
            <h3 class="paper-title">${p.title}</h3>
            <div class="paper-info">
              <span>📄 ${p.mcqs} MCQs</span>
              <span>⏱ ${p.minutes} Min</span>
              <span>${p.solved ? '✅ Solved' : '📋 Unsolved'}</span>
            </div>
            <div class="paper-tags">${p.subjects.map(s=>`<span class="paper-tag">${s}</span>`).join('')}</div>
            <div class="paper-actions">
              <a href="/past-papers/${p.id}"  class="btn btn-ghost btn-sm">View Paper</a>
              <a href="/quiz/paper/${p.id}"   class="btn btn-navy btn-sm">⏱ Attempt with Timer</a>
            </div>
          </article>`)
        .join('');
    }

    // ── MOTIVATION QUOTES ────────────────────────────────────────
    const quotes = [
      { text:"The secret of getting ahead is getting started.",                     author:"Mark Twain" },
      { text:"Success is the sum of small efforts, repeated day in and day out.",   author:"Robert Collier" },
      { text:"Don't watch the clock; do what it does. Keep going.",                 author:"Sam Levenson" },
      { text:"Hard work beats talent when talent doesn't work hard.",               author:"Tim Notke" },
    ];
    let currentQuote = 0;

    function setQuote(i) {
      const qEl = document.getElementById('motivation-quote');
      const aEl = document.getElementById('motivation-author');
      const dots = document.querySelectorAll('.motivation-dots span');
      if (!qEl || !aEl) return;
      qEl.style.opacity = aEl.style.opacity = '0';
      setTimeout(() => {
        qEl.textContent = `"${quotes[i].text}"`;
        aEl.textContent = quotes[i].author;
        qEl.style.opacity = aEl.style.opacity = '1';
      }, 320);
      dots.forEach((d, idx) => {
        d.classList.toggle('active', idx === i);
        d.setAttribute('aria-selected', String(idx === i));
      });
      currentQuote = i;
    }

    // ── MOBILE NAV ───────────────────────────────────────────────
    function initMobileNav() {
      const btn   = document.querySelector('.nav-hamburger');
      const links = document.querySelector('.nav-links');
      if (!btn || !links) return;
      btn.addEventListener('click', () => {
        const open = links.style.display === 'flex';
        links.style.cssText = open ? '' :
          'display:flex;flex-direction:column;position:absolute;top:66px;left:0;right:0;background:white;padding:16px 24px;border-bottom:1px solid #E2D9C6;z-index:99;gap:4px;box-shadow:0 8px 24px rgba(0,0,0,0.1);';
        btn.setAttribute('aria-expanded', String(!open));
      });
    }

    // ── INIT ─────────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
      // Smooth quote transitions
      ['motivation-quote','motivation-author'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.style.transition = 'opacity 0.32s ease';
      });

      // Dot click
      document.querySelectorAll('.motivation-dots span').forEach((dot, i) => {
        dot.addEventListener('click', () => setQuote(i));
        dot.addEventListener('keydown', e => {
          if (e.key === 'Enter' || e.key === ' ') setQuote(i);
        });
      });

      // Auto-rotate
      setInterval(() => setQuote((currentQuote + 1) % quotes.length), 6000);

      renderDepartments();
      renderLatestPapers();
      initMobileNav();
    });
  </script>

