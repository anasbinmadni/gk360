---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GK360 | Best PPSC Preparation Academy</title>
  </head>
  <body class="bg-dots text-ink font-sans min-h-screen">
    
    <nav class="py-6 px-6">
      <div class="max-w-6xl mx-auto flex justify-between items-center bg-white/80 backdrop-blur-md px-6 py-4 rounded-2xl border border-slate-200 shadow-sm">
        <div class="text-2xl font-black tracking-tight">GK360<span class="text-accent">.pk</span></div>
        <div class="space-x-8 text-sm font-bold text-slate-600 hidden md:block">
          <a href="#" class="hover:text-accent transition">Past Papers</a>
          <a href="#" class="hover:text-accent transition">Subject MCQs</a>
          <a href="#" class="bg-ink text-paper px-6 py-2.5 rounded-full hover:-translate-y-0.5 transition duration-200 shadow-md">Login</a>
        </div>
      </div>
    </nav>

    <main class="max-w-6xl mx-auto px-4 py-16">
      <div class="text-center py-16 mb-16">
        <div class="inline-block border border-slate-300 bg-white px-4 py-1.5 rounded-full text-sm font-bold tracking-widest uppercase text-slate-500 mb-8 shadow-sm">
          Punjab Public Service Commission
        </div>
        
        <h1 class="text-5xl md:text-7xl font-extrabold mt-4 mb-8 leading-tight tracking-tight text-ink">
          Study Smarter, Not <br/> 
          <span class="highlight-text text-slate-800">Harder</span> for PPSC.
        </h1>
        
        <p class="text-xl text-slate-600 mb-10 max-w-2xl mx-auto leading-relaxed font-medium">
          Pakistan's most productive preparation platform. Stop memorizing blindly. Get solved past papers and secure your government job.
        </p>
        
        <div class="flex justify-center gap-4">
          <a href="#" class="bg-accent text-white px-8 py-4 rounded-xl font-bold hover:bg-teal-800 transition shadow-lg shadow-teal-900/20 text-lg hover:-translate-y-1">Start Practicing Free</a>
        </div>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white p-8 rounded-3xl border-2 border-slate-100 shadow-[4px_4px_0px_0px_rgba(226,232,240,1)] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_rgba(226,232,240,1)] transition-all">
          <div class="text-4xl mb-6">📝</div>
          <h3 class="text-xl font-bold mb-3">Logical Explanations</h3>
          <p class="text-slate-600 font-medium leading-relaxed">Every single MCQ comes with a detailed breakdown so you actually learn the concept.</p>
        </div>

        <div class="bg-white p-8 rounded-3xl border-2 border-slate-100 shadow-[4px_4px_0px_0px_rgba(226,232,240,1)] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_rgba(226,232,240,1)] transition-all">
          <div class="text-4xl mb-6">🎯</div>
          <h3 class="text-xl font-bold mb-3">Topic-Wise MCQs</h3>
          <p class="text-slate-600 font-medium leading-relaxed">Master the syllabus systematically. Practice highly targeted questions for every core subject.</p>
        </div>

        <div class="bg-white p-8 rounded-3xl border-2 border-slate-100 shadow-[4px_4px_0px_0px_rgba(226,232,240,1)] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_rgba(226,232,240,1)] transition-all">
          <div class="text-4xl mb-6">⚡</div>
          <h3 class="text-xl font-bold mb-3">Spaced Repetition</h3>
          <p class="text-slate-600 font-medium leading-relaxed">Built-in study techniques to ensure you never forget what you've learned on exam day.</p>
        </div>
      </div>
    </main>

  </body>
</html>