---
// src/pages/english/[section].astro
// Auto-generates: /english/vocabulary/, /english/grammar/, /english/idioms/
// MCQs are auto-pulled and routed from all past papers

import BaseLayout from '../../layouts/BaseLayout.astro';
import { ENGLISH_SECTIONS, getSection, routeToEnglishSection } from '../../data/english';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  // Only generate for sections that have MCQs (not introduction — it has its own page)
  return ENGLISH_SECTIONS.filter(s => s.slug !== 'introduction').map(sec => ({
    params: { section: sec.slug },
    props:  { section: sec },
  }));
}

const { section } = Astro.props;

// Pull all MCQs for this English sub-section from every paper
const allPapers = await getCollection('past-papers');

interface MCQItem {
  question:   any;
  paperTitle: string;
  paperSlug:  string;
  year:       number;
  dept:       string;
}

const mcqs: MCQItem[] = [];
allPapers.forEach(paper => {
  paper.data.questions
    ?.filter((q: any) => q.subject === 'english')
    .filter((q: any) => routeToEnglishSection(q.topic || '') === section.slug)
    .forEach((q: any) => {
      mcqs.push({
        question:   q,
        paperTitle: paper.data.title,
        paperSlug:  paper.data.slug,
        year:       paper.data.year,
        dept:       paper.data.departmentShort,
      });
    });
});

// Sort newest first
mcqs.sort((a, b) => b.year - a.year);

// Topic breakdown within this section
const topicMap: Record<string, number> = {};
mcqs.forEach(m => {
  const t = m.question.topic || 'General';
  topicMap[t] = (topicMap[t] || 0) + 1;
});
const topics = Object.entries(topicMap).sort((a, b) => b[1] - a[1]);

// Related papers
const relatedPapers = [...new Map(
  mcqs.map(m => [m.paperSlug, { title: m.paperTitle, slug: m.paperSlug, year: m.year, dept: m.dept }])
).values()].slice(0, 6);

// Other English sections for sidebar
const otherSections = ENGLISH_SECTIONS.filter(s => s.slug !== section.slug);

const title       = `${section.name} — PPSC English MCQs | GK360.pk`;
const description = `${mcqs.length}+ ${section.name} MCQs from real PPSC past papers with answer keys. ${section.description.split('.')[0]}.`;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LearningResource",
  "name": `${section.name} — PPSC English`,
  "description": description,
  "url": `https://gk360.pk/english/${section.slug}/`,
  "educationalLevel": "professional",
  "provider": { "@type": "Organization", "name": "GK360.pk" }
});
---

<BaseLayout title={title} description={description}
  keywords={`${section.name} PPSC, English ${section.slug} past papers, ${section.name} MCQs, PPSC English preparation`}
  schema={schema}>

<!-- BREADCRUMB -->
<nav class="bc-nav" aria-label="Breadcrumb">
  <div class="container">
    <ol class="bc-ol">
      <li><a href="/">Home</a></li><li aria-hidden="true">›</li>
      <li><a href="/english/">English Corner</a></li><li aria-hidden="true">›</li>
      <li class="bc-current">{section.name}</li>
    </ol>
  </div>
</nav>

<!-- HERO -->
<div class="es-hero">
  <div class="container">
    <div class="es-hero-inner">
      <div class="es-icon" aria-hidden="true">{section.icon}</div>
      <div class="es-info">
        <p class="label label-light">English Corner</p>
        <h1>{section.name}</h1>
        <p class="es-desc">{section.description}</p>

        <!-- Exam Tip -->
        <div class="es-exam-tip">
          <span class="es-tip-icon">💡</span>
          <div>
            <strong>Exam Tip:</strong> {section.examTip}
          </div>
        </div>

        <div class="es-stats">
          <span>📝 <b>{mcqs.length}</b> MCQs</span>
          <span class="es-dot">·</span>
          <span>📄 From <b>{relatedPapers.length}</b> Papers</span>
          <span class="es-dot">·</span>
          <span>✅ With Answer Keys</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- CONTENT -->
<div class="es-page">
  <div class="container">
    <div class="es-layout">

      <!-- MAIN -->
      <main class="es-main">

        {mcqs.length === 0 ? (
          <div class="es-empty">
            <div class="es-empty-icon">{section.icon}</div>
            <h2>MCQs Coming Soon</h2>
            <p>We're building the {section.name} bank from past papers. Add more paper JSONs to see questions here automatically.</p>
            <a href="/english/" class="btn-gold" style="margin-top:20px;display:inline-flex;">← Back to English Corner</a>
          </div>
        ) : (
          <>
            <!-- TOPIC BREAKDOWN -->
            {topics.length > 1 && (
              <div class="es-topics-card">
                <h2 class="es-topics-title">Topics Covered</h2>
                <div class="es-topics-grid">
                  {topics.map(([topic, count]) => (
                    <button class="es-topic-chip topic-filter-btn" data-topic={topic}>
                      {topic.replace('English — ', '')}
                      <span class="etc-count">{count}</span>
                    </button>
                  ))}
                  <button class="es-topic-chip es-topic-all active" data-topic="all">
                    All Topics
                    <span class="etc-count">{mcqs.length}</span>
                  </button>
                </div>
              </div>
            )}

            <!-- MCQ LIST -->
            <div class="es-mcq-list" id="es-mcq-list">
              {mcqs.map((item, idx) => (
                <div class="es-mcq-card" data-topic={item.question.topic} data-idx={idx} id={`emc-${idx}`}>

                  <!-- Header -->
                  <div class="es-mcq-hdr">
                    <span class="es-mcq-num">Q.{idx + 1}</span>
                    <a href={`/past-papers/${item.paperSlug}/`} class="es-mcq-src" aria-label={`Source: ${item.dept} ${item.year}`}>
                      {item.dept} {item.year}
                    </a>
                    {item.question.topic && (
                      <span class="es-mcq-topic">{item.question.topic.replace('English — ', '')}</span>
                    )}
                  </div>

                  <!-- Question -->
                  <p class="es-mcq-q">{item.question.question}</p>

                  <!-- Options 2-per-row -->
                  <div class="es-opts" id={`eo-${idx}`}>
                    {Object.entries(item.question.options as Record<string,string>).map(([k, v]) => (
                      <button
                        class="es-opt"
                        data-q={idx}
                        data-k={k}
                        data-correct={item.question.correct}
                        aria-label={`Option ${k}: ${v}`}
                      >
                        <span class="es-opt-key">{k}</span>
                        <span class="es-opt-val">{v}</span>
                      </button>
                    ))}
                  </div>

                  <!-- Answer (hidden until answered) -->
                  <div class="es-answer" id={`ea-${idx}`} hidden>
                    <div class="es-ans-correct">
                      ✅ <strong>Correct Answer:</strong> {item.question.correct} — {(item.question.options as Record<string,string>)[item.question.correct]}
                    </div>
                    {item.question.explanation && (
                      <div class="es-explanation">
                        <span class="es-exp-icon">💡</span>
                        <p>{item.question.explanation}</p>
                      </div>
                    )}
                    <a href={`/past-papers/${item.paperSlug}/`} class="es-paper-link">
                      View full paper: {item.paperTitle} {item.year} →
                    </a>
                  </div>

                </div>
              ))}
            </div>

            <!-- LOAD MORE -->
            <div class="es-load-wrap" id="es-load-wrap">
              <button class="es-load-btn" id="es-load-btn">Load More MCQs</button>
              <p class="es-load-hint" id="es-load-hint"></p>
            </div>
          </>
        )}

      </main>

      <!-- SIDEBAR -->
      <aside class="es-sidebar">

        <!-- Other English sections -->
        <div class="es-sb-card">
          <h3 class="es-sb-title">English Corner</h3>
          <div class="es-sb-links">
            <a href="/english/" class="es-sb-link">🏠 English Hub</a>
            {otherSections.map(s => (
              <a href={`/english/${s.slug}/`} class="es-sb-link">
                {s.icon} {s.short} <span>→</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Papers with this section -->
        {relatedPapers.length > 0 && (
          <div class="es-sb-card">
            <h3 class="es-sb-title">Source Papers</h3>
            <div class="es-sb-papers">
              {relatedPapers.map(p => (
                <a href={`/past-papers/${p.slug}/`} class="es-sb-paper">
                  <span class="esbp-dept">{p.dept}</span>
                  <span class="esbp-year">{p.year}</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- VoxEnglish CTA -->
        <div class="es-sb-card es-sb-vox">
          <div class="esvox-icon">🎤</div>
          <h3>Improve Your Spoken English</h3>
          <p>Powered by VoxEnglishAcademy — practice self-introduction, interview skills, and confident communication.</p>
          <a href="/english/introduction/" class="btn-gold" style="width:100%;justify-content:center;margin-top:4px;">
            Start Practice →
          </a>
          <a href="https://www.voxenglishacademy.com" target="_blank" rel="noopener noreferrer" class="esvox-ext">
            Visit VoxEnglishAcademy.com ↗
          </a>
        </div>

        <!-- Subject links -->
        <div class="es-sb-card">
          <h3 class="es-sb-title">Other Subjects</h3>
          <div class="es-sb-links">
            <a href="/subjects/general-knowledge/"  class="es-sb-link">🌍 General Knowledge <span>→</span></a>
            <a href="/subjects/islamiyat/"           class="es-sb-link">☪️ Islamiyat <span>→</span></a>
            <a href="/subjects/pakistan-studies/"    class="es-sb-link">🗺️ Pakistan Studies <span>→</span></a>
            <a href="/subjects/basic-mathematics/"   class="es-sb-link">🔢 Mathematics <span>→</span></a>
            <a href="/subjects/"                     class="es-sb-link" style="border-color:var(--navy)">All Subjects →</a>
          </div>
        </div>

      </aside>
    </div>
  </div>
</div>

<style is:global>
/* Hero */
.es-hero { background:linear-gradient(160deg,var(--navy) 0%,#0f2550 100%); padding:60px 24px 72px; position:relative; overflow:hidden; }
.es-hero::before { content:''; position:absolute; inset:0; background-image:linear-gradient(rgba(197,150,58,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(197,150,58,.035) 1px,transparent 1px); background-size:56px 56px; pointer-events:none; }
.es-hero-inner { position:relative; z-index:1; display:flex; align-items:flex-start; gap:24px; max-width:820px; }
.es-icon { font-size:52px; background:rgba(197,150,58,.1); border:1px solid rgba(197,150,58,.2); border-radius:16px; width:80px; height:80px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.es-info .label { color:rgba(197,150,58,.85); }
.es-info h1 { font-family:'Playfair Display',Georgia,serif; color:var(--white); font-size:clamp(24px,3.5vw,40px); font-weight:700; margin-bottom:12px; text-align:left; }
.es-desc { font-size:15px; color:rgba(255,255,255,.65); margin-bottom:16px; line-height:1.75; text-align:left; max-width:580px; }
.es-exam-tip { display:flex; gap:10px; background:rgba(197,150,58,.1); border:1px solid rgba(197,150,58,.22); border-radius:var(--radius); padding:12px 16px; margin-bottom:18px; font-size:14px; color:rgba(255,255,255,.8); line-height:1.6; }
.es-tip-icon { font-size:18px; flex-shrink:0; }
.es-stats { display:flex; align-items:center; gap:12px; flex-wrap:wrap; font-size:14px; color:rgba(255,255,255,.7); }
.es-stats b { color:var(--gold-light); }
.es-dot { color:rgba(255,255,255,.25); }

/* Page */
.es-page { background:var(--cream); padding:40px 0 72px; }
.es-layout { display:grid; grid-template-columns:1fr 280px; gap:24px; align-items:start; }

/* Topics card */
.es-topics-card { background:var(--white); border:1.5px solid var(--border); border-radius:var(--radius-lg); padding:22px 24px; margin-bottom:16px; }
.es-topics-title { font-family:'Playfair Display',Georgia,serif; font-size:18px; font-weight:700; color:var(--navy); margin-bottom:14px; text-align:left; }
.es-topics-grid { display:flex; gap:8px; flex-wrap:wrap; }
.es-topic-chip { font-size:12px; font-weight:700; padding:7px 14px; border-radius:100px; border:1.5px solid var(--border); background:var(--white); color:var(--text-muted); cursor:pointer; transition:all .18s; font-family:'Plus Jakarta Sans',system-ui,sans-serif; display:flex; align-items:center; gap:6px; }
.es-topic-chip:hover { border-color:var(--navy); color:var(--navy); }
.es-topic-chip.active { background:var(--navy); color:var(--white); border-color:var(--navy); }
.etc-count { font-size:11px; background:rgba(255,255,255,.2); padding:1px 6px; border-radius:10px; }
.es-topic-chip:not(.active) .etc-count { background:var(--cream); color:var(--text-muted); }

/* MCQ List */
.es-mcq-list { display:flex; flex-direction:column; gap:0; }
.es-mcq-card {
  background:var(--white);
  border-left:1.5px solid var(--border);
  border-right:1.5px solid var(--border);
  border-top:1.5px solid var(--border);
  border-bottom:none;
  padding:22px 24px;
  transition:background .18s;
}
.es-mcq-card:first-child { border-radius:var(--radius-lg) var(--radius-lg) 0 0; }
.es-mcq-card:last-child  { border-bottom:1.5px solid var(--border); border-radius:0 0 var(--radius-lg) var(--radius-lg); }
.es-mcq-card+.es-mcq-card { border-top:1px solid var(--border); }
.es-mcq-card.es-done { background:rgba(11,29,58,.02); }

.es-mcq-hdr { display:flex; align-items:center; gap:8px; margin-bottom:12px; flex-wrap:wrap; }
.es-mcq-num { font-size:11px; font-weight:800; background:var(--navy); color:var(--gold-light); padding:4px 10px; border-radius:5px; letter-spacing:.05em; }
.es-mcq-src { font-size:11px; font-weight:700; padding:3px 9px; background:rgba(197,150,58,.1); border:1px solid rgba(197,150,58,.22); color:var(--gold-dark); border-radius:5px; text-decoration:none; transition:background .18s; }
.es-mcq-src:hover { background:rgba(197,150,58,.2); }
.es-mcq-topic { font-size:11px; color:var(--text-muted); font-weight:500; }

.es-mcq-q { font-size:15px; font-weight:600; color:var(--navy); line-height:1.6; margin-bottom:16px; text-align:left; }

/* Options — 2 per row like paper page */
.es-opts { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.es-opt { display:flex; align-items:stretch; border-radius:var(--radius); overflow:hidden; border:2px solid var(--border); cursor:pointer; transition:all .18s; background:var(--white); text-align:left; width:100%; font-family:'Plus Jakarta Sans',system-ui,sans-serif; }
.es-opt:hover:not([disabled]):not(.es-opt-sel):not(.es-opt-ok):not(.es-opt-no) { border-color:var(--navy); box-shadow:0 2px 10px rgba(11,29,58,.1); }
.es-opt[disabled] { cursor:default; }
.es-opt-key { display:flex; align-items:center; justify-content:center; min-width:44px; background:var(--cream); border-right:2px solid var(--border); font-size:14px; font-weight:800; color:var(--navy); flex-shrink:0; padding:13px 10px; transition:all .18s; }
.es-opt-val { font-size:14px; font-weight:500; color:var(--text-body); padding:13px 14px; line-height:1.45; flex:1; display:flex; align-items:center; }

/* States */
.es-opt-sel { border-color:var(--navy); }
.es-opt-sel .es-opt-key { background:var(--navy); border-right-color:var(--navy); color:var(--gold-light); }
.es-opt-sel .es-opt-val { color:var(--navy); font-weight:600; background:rgba(11,29,58,.04); }
.es-opt-ok { border-color:#1A7A40; }
.es-opt-ok .es-opt-key { background:#1A7A40; border-right-color:#1A7A40; color:white; }
.es-opt-ok .es-opt-val { color:#1A7A40; font-weight:600; background:rgba(26,122,64,.04); }
.es-opt-no { border-color:#dc2626; }
.es-opt-no .es-opt-key { background:#dc2626; border-right-color:#dc2626; color:white; }
.es-opt-no .es-opt-val { color:#dc2626; font-weight:600; background:rgba(220,38,38,.03); }

/* Answer panel */
.es-answer { background:var(--cream); border-radius:var(--radius); padding:16px 18px; margin-top:14px; display:flex; flex-direction:column; gap:10px; }
.es-ans-correct { font-size:15px; color:#1A7A40; font-weight:600; }
.es-explanation { display:flex; gap:10px; background:rgba(197,150,58,.08); border:1px solid rgba(197,150,58,.2); border-radius:var(--radius); padding:14px; }
.es-exp-icon { font-size:18px; flex-shrink:0; }
.es-explanation p { font-size:14px; color:var(--text-body); line-height:1.7; text-align:left; margin:0; }
.es-paper-link { font-size:13px; font-weight:600; color:var(--navy); text-decoration:none; border-bottom:1px solid var(--border); padding-bottom:1px; align-self:flex-start; transition:color .18s, border-color .18s; }
.es-paper-link:hover { color:var(--gold-dark); border-color:var(--gold-dark); }

/* Load more */
.es-load-wrap { text-align:center; padding:24px 0; }
.es-load-btn { font-size:15px; font-weight:600; padding:13px 36px; border-radius:var(--radius); border:1.5px solid var(--navy); background:var(--white); color:var(--navy); cursor:pointer; transition:all .2s; font-family:'Plus Jakarta Sans',system-ui,sans-serif; }
.es-load-btn:hover { background:var(--navy); color:var(--white); }
.es-load-hint { font-size:13px; color:var(--text-muted); margin-top:8px; }

/* Empty */
.es-empty { background:var(--white); border:1.5px solid var(--border); border-radius:var(--radius-xl); padding:60px 40px; text-align:center; }
.es-empty-icon { font-size:52px; margin-bottom:16px; }
.es-empty h2 { font-family:'Playfair Display',Georgia,serif; font-size:24px; color:var(--navy); margin-bottom:10px; text-align:center; }
.es-empty p { color:var(--text-muted); font-size:15px; text-align:center; max-width:400px; margin:0 auto; }

/* Sidebar */
.es-sidebar { display:flex; flex-direction:column; gap:18px; }
.es-sb-card { background:var(--white); border:1.5px solid var(--border); border-radius:var(--radius-lg); padding:22px 24px; }
.es-sb-vox  { background:var(--navy); border-color:var(--navy); text-align:center; }
.es-sb-vox .esvox-icon { font-size:36px; margin-bottom:10px; }
.es-sb-vox h3 { font-family:'Playfair Display',Georgia,serif; font-size:17px; color:var(--white); margin-bottom:8px; text-align:center; }
.es-sb-vox p  { font-size:13px; color:rgba(255,255,255,.6); margin-bottom:16px; text-align:center; line-height:1.6; }
.esvox-ext { display:block; font-size:12px; color:rgba(255,255,255,.5); text-decoration:none; margin-top:12px; transition:color .18s; }
.esvox-ext:hover { color:var(--gold-light); }
.es-sb-title { font-family:'Playfair Display',Georgia,serif; font-size:16px; font-weight:700; color:var(--navy); margin-bottom:16px; text-align:left; }
.es-sb-links { display:flex; flex-direction:column; gap:8px; }
.es-sb-link { display:flex; justify-content:space-between; align-items:center; padding:10px 12px; background:var(--cream); border:1px solid var(--border); border-radius:8px; text-decoration:none; font-size:13px; font-weight:600; color:var(--navy); transition:all .18s; }
.es-sb-link:hover { background:var(--cream-dark); border-color:var(--navy); }
.es-sb-papers { display:flex; flex-direction:column; gap:8px; }
.es-sb-paper { display:flex; justify-content:space-between; align-items:center; padding:10px 12px; background:var(--cream); border:1px solid var(--border); border-radius:8px; text-decoration:none; font-size:13px; transition:all .18s; }
.es-sb-paper:hover { background:var(--cream-dark); border-color:var(--navy); }
.esbp-dept { font-size:11px; font-weight:800; padding:2px 8px; background:var(--navy); color:var(--gold-light); border-radius:4px; }
.esbp-year { font-size:12px; font-weight:700; color:var(--text-muted); }

/* btn-gold */
.btn-gold { display:inline-flex; align-items:center; justify-content:center; gap:8px; background:var(--gold); color:var(--navy); border:2px solid var(--gold); font-family:'Plus Jakarta Sans',system-ui,sans-serif; font-size:15px; font-weight:700; padding:13px 28px; border-radius:var(--radius); cursor:pointer; transition:all .22s; white-space:nowrap; text-decoration:none; }
.btn-gold:hover { background:var(--gold-light); border-color:var(--gold-light); transform:translateY(-1px); }

@media (max-width:960px) { .es-layout { grid-template-columns:1fr; } .es-sidebar { display:grid; grid-template-columns:1fr 1fr; gap:16px; } }
@media (max-width:640px) {
  .es-hero-inner { flex-direction:column; gap:16px; }
  .es-icon { width:60px; height:60px; font-size:30px; }
  .es-sidebar { grid-template-columns:1fr; }
  .es-opts { grid-template-columns:1fr; }
}
</style>

<script>
// ── OPTION SELECTION (event delegation) ──────────────────────────
document.addEventListener('click', (e: Event) => {
  const opt = (e.target as Element).closest('.es-opt') as HTMLButtonElement | null;
  if (!opt || opt.disabled) return;

  const idx     = opt.dataset.q!;
  const chosen  = opt.dataset.k!;
  const correct = opt.dataset.correct!;
  const optsWrap = document.getElementById(`eo-${idx}`)!;
  const ansWrap  = document.getElementById(`ea-${idx}`)!;
  const card     = opt.closest('.es-mcq-card') as HTMLElement;

  // Disable all & apply colours
  optsWrap.querySelectorAll('.es-opt').forEach((b: Element) => {
    const btn = b as HTMLButtonElement;
    btn.setAttribute('disabled', '');
    const k = btn.dataset.k!;
    btn.classList.remove('es-opt-sel');
    if (k === correct)                  btn.classList.add('es-opt-ok');
    else if (k === chosen)              btn.classList.add('es-opt-no');
  });

  ansWrap.hidden = false;
  card.classList.add('es-done');
});

// ── TOPIC FILTER ──────────────────────────────────────────────────
const topicBtns = document.querySelectorAll('.es-topic-chip');
const mcqCards  = document.querySelectorAll('.es-mcq-card') as NodeListOf<HTMLElement>;

topicBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    topicBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const filter = (btn as HTMLElement).dataset.topic!;

    mcqCards.forEach(card => {
      const show = filter === 'all' || card.dataset.topic === filter;
      card.style.display = show ? '' : 'none';
    });

    // Fix border radius after filter
    const visible = [...mcqCards].filter(c => c.style.display !== 'none');
    visible.forEach((c, i) => {
      c.style.borderRadius = '';
      c.style.borderBottom = '';
      if (i === 0 && visible.length === 1) {
        c.style.borderRadius = 'var(--radius-lg)';
        c.style.borderBottom = '1.5px solid var(--border)';
      } else if (i === 0) {
        c.style.borderRadius = 'var(--radius-lg) var(--radius-lg) 0 0';
      } else if (i === visible.length - 1) {
        c.style.borderRadius = '0 0 var(--radius-lg) var(--radius-lg)';
        c.style.borderBottom = '1.5px solid var(--border)';
      }
    });

    // Reset load more
    shown = Math.min(BATCH, visible.length);
    updateLoadMore(visible);
  });
});

// ── PROGRESSIVE LOAD ──────────────────────────────────────────────
const BATCH = 20;
let shown   = Math.min(BATCH, mcqCards.length);

function getVisible(): HTMLElement[] {
  return [...mcqCards].filter(c => c.style.display !== 'none');
}

function updateLoadMore(visible: HTMLElement[]) {
  const wrap = document.getElementById('es-load-wrap');
  const hint = document.getElementById('es-load-hint');
  if (!wrap) return;
  const remaining = visible.length - shown;
  wrap.style.display = remaining <= 0 ? 'none' : '';
  if (hint) hint.textContent = remaining > 0 ? `${remaining} more MCQs available` : '';
}

// Initial: hide cards beyond BATCH
if (mcqCards.length > BATCH) {
  mcqCards.forEach((c, i) => { if (i >= BATCH) c.style.display = 'none'; });
  updateLoadMore(getVisible());
} else {
  const wrap = document.getElementById('es-load-wrap');
  if (wrap) wrap.style.display = 'none';
}

document.getElementById('es-load-btn')?.addEventListener('click', () => {
  const visible = getVisible();
  const hidden  = visible.filter(c => c.style.display === 'none');
  hidden.slice(0, BATCH).forEach(c => { c.style.display = ''; });
  shown = Math.min(shown + BATCH, visible.length);
  updateLoadMore(visible);
});
</script>

</BaseLayout>