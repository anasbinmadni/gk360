---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SUBJECTS } from '../../data/subjects';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return SUBJECTS.map(sub => ({
    params: { subject: sub.slug },
    props:  { sub },
  }));
}

const { sub: subject } = Astro.props;

const allPapers = await getCollection('past-papers');

// Explicitly type everything as any to prevent template TypeScript errors
interface MCQItem {
  q:     any;
  title: string;
  slug:  string;
  year:  number;
  dept:  string;
}

const mcqs: MCQItem[] = [];
allPapers.forEach((paper) => {
  const d = paper.data as any;
  const questions: any[] = d.questions || [];
  questions
    .filter((q: any) => q.subject === subject.slug)
    .forEach((q: any) => {
      mcqs.push({ q, title: d.title, slug: d.slug, year: d.year, dept: d.departmentShort });
    });
});
mcqs.sort((a, b) => b.year - a.year);

// Related papers
const relatedPapers = allPapers
  .filter((p) => {
    const d = p.data as any;
    return (d.subjectBreakdown || []).some((s: any) => s.subject === subject.slug);
  })
  .map((p) => p.data as any)
  .sort((a: any, b: any) => b.year - a.year)
  .slice(0, 6);

// Counts
const staticCount  = mcqs.filter(m => m.q.type === 'static').length;
const dynamicCount = mcqs.filter(m => m.q.type === 'dynamic').length;

// Topic breakdown
const topicMap: Record<string, number> = {};
mcqs.forEach(m => { const t = m.q.topic || 'General'; topicMap[t] = (topicMap[t] || 0) + 1; });
const topTopics = Object.entries(topicMap).sort((a, b) => b[1] - a[1]).slice(0, 8);

const otherSubjects = SUBJECTS.filter(s => s.importance === 'core' && s.slug !== subject.slug).slice(0, 6);

const title       = `${subject.name} MCQs — PPSC Past Papers Questions | GK360.pk`;
const description = `${mcqs.length}+ ${subject.name} MCQs from real PPSC past papers with answer keys. ${subject.description.split('.')[0]}.`;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LearningResource",
  "name": `${subject.name} MCQs — PPSC Past Papers`,
  "description": description,
  "url": `https://gk360.pk/subjects/${subject.slug}/`,
  "educationalLevel": "professional",
  "provider": { "@type": "Organization", "name": "GK360.pk" }
});
---

<BaseLayout title={title} description={description}
  keywords={`${subject.name} PPSC MCQs, ${subject.short} past paper questions, ${subject.name} solved MCQs`}
  schema={schema}>

<nav class="bc-nav" aria-label="Breadcrumb">
  <div class="container">
    <ol class="bc-ol">
      <li><a href="/">Home</a></li><li aria-hidden="true">›</li>
      <li><a href="/subjects/">Subjects</a></li><li aria-hidden="true">›</li>
      <li class="bc-current">{subject.name}</li>
    </ol>
  </div>
</nav>

<!-- HERO -->
<div class="sh-hero">
  <div class="container">
    <div class="sh-hero-inner">
      <div class="sh-icon">{subject.icon}</div>
      <div class="sh-info">
        <p class="label label-light">{subject.category}</p>
        <h1>{subject.name}</h1>
        <p class="sh-desc">{subject.description}</p>
        <div class="sh-stats">
          <span>📝 <b>{mcqs.length}</b> MCQs</span>
          <span class="sh-dot">·</span>
          <span>📄 <b>{relatedPapers.length}</b> Papers</span>
          <span class="sh-dot">·</span>
          <span>📌 <b>{staticCount}</b> Static</span>
          <span class="sh-dot">·</span>
          <span>🔄 <b>{dynamicCount}</b> Current</span>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="sp-page">
  <div class="container">
    <div class="sp-layout">

      <main class="sp-main">
        {mcqs.length === 0 ? (
          <div class="sp-empty">
            <div class="sp-empty-icon">{subject.icon}</div>
            <h2>MCQs Coming Soon</h2>
            <p>Add more past paper JSON files — {subject.name} questions will appear here automatically.</p>
            <a href="/past-papers/" class="sp-btn-gold" style="margin-top:20px;display:inline-flex;">Browse Past Papers →</a>
          </div>
        ) : (
          <div>
            {topTopics.length > 1 && (
              <div class="sp-topics-wrap">
                <p class="sp-topics-label">Topics covered:</p>
                <div class="sp-topics">
                  {topTopics.map(([topic, count]) => (
                    <span class="sp-topic-chip">{topic} <b>{count}</b></span>
                  ))}
                </div>
              </div>
            )}

            <div class="sp-filter-bar">
              <button class="sp-filter-btn active" data-filter="all">All ({mcqs.length})</button>
              <button class="sp-filter-btn" data-filter="static">📌 Static ({staticCount})</button>
              <button class="sp-filter-btn" data-filter="dynamic">🔄 Current ({dynamicCount})</button>
            </div>

            <div class="sp-mcq-list" id="sp-mcq-list">
              {mcqs.map((item, idx) => (
                <div class="sp-mcq-card" data-type={item.q.type} id={`smc-${idx}`}>
                  <div class="sp-mcq-hdr">
                    <span class="sp-mcq-num">Q.{idx + 1}</span>
                    <a href={`/past-papers/${item.slug}/`} class="sp-mcq-source">{item.dept} {item.year}</a>
                    {item.q.topic && <span class="sp-mcq-topic">{item.q.topic}</span>}
                  </div>
                  <p class="sp-mcq-text">{item.q.question}</p>
                  <div class="sp-opts" id={`so-${idx}`}>
                    {Object.entries(item.q.options as Record<string,string>).map(([k, v]) => (
                      <button class="sp-opt" data-q={idx} data-k={k} data-correct={item.q.correct}>
                        <span class="sp-opt-key">{k}</span>
                        <span class="sp-opt-val">{v}</span>
                      </button>
                    ))}
                  </div>
                  <div class="sp-answer" id={`sa-${idx}`} hidden>
                    <span class="sp-ans-label">✅ Correct Answer:</span>
                    <span class="sp-ans-val">{item.q.correct} — {(item.q.options as Record<string,string>)[item.q.correct]}</span>
                    {item.q.explanation && (
                      <div class="sp-explanation">
                        <span class="sp-exp-icon">💡</span>
                        <p>{item.q.explanation}</p>
                      </div>
                    )}
                    <a href={`/past-papers/${item.slug}/`} class="sp-full-paper-link">View full paper →</a>
                  </div>
                </div>
              ))}
            </div>

            <div class="sp-load-more-wrap" id="sp-load-more">
              <button class="sp-btn-load" id="sp-load-btn">Load More MCQs</button>
            </div>
          </div>
        )}
      </main>

      <aside class="sp-sidebar">
        {relatedPapers.length > 0 && (
          <div class="sp-sb-card">
            <h3 class="sp-sb-title">Papers with {subject.short}</h3>
            <div class="sp-sb-papers">
              {relatedPapers.map((p: any) => (
                <a href={`/past-papers/${p.slug}/`} class="sp-sb-paper">
                  <div class="sp-sbp-top">
                    <span class="sp-sbp-dept">{p.departmentShort}</span>
                    <span class="sp-sbp-year">{p.year}</span>
                  </div>
                  <div class="sp-sbp-title">{p.title}</div>
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="sp-sb-card">
          <h3 class="sp-sb-title">Other Subjects</h3>
          <div class="sp-sb-links">
            {otherSubjects.map(s => (
              <a href={`/subjects/${s.slug}/`} class="sp-sb-link">{s.icon} {s.short} <span>→</span></a>
            ))}
            <a href="/subjects/" class="sp-sb-link sp-sb-link--all">All Subjects →</a>
          </div>
        </div>

        <div class="sp-sb-card sp-sb-card--cta">
          <div class="sp-sb-cta-icon">🎯</div>
          <h3>Practice Full Papers</h3>
          <p>Attempt complete past papers with a 90-minute timer.</p>
          <a href="/past-papers/" class="sp-btn-gold">Browse Papers →</a>
        </div>
      </aside>
    </div>
  </div>
</div>

<style is:global>
.sh-hero { background:var(--navy); padding:60px 24px 72px; position:relative; overflow:hidden; }
.sh-hero::before { content:''; position:absolute; inset:0; background-image:linear-gradient(rgba(197,150,58,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(197,150,58,.04) 1px,transparent 1px); background-size:56px 56px; pointer-events:none; }
.sh-hero-inner { position:relative; z-index:1; display:flex; align-items:flex-start; gap:24px; max-width:820px; }
.sh-icon { font-size:52px; background:rgba(197,150,58,.1); border:1px solid rgba(197,150,58,.2); border-radius:16px; width:80px; height:80px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.sh-info .label { color:rgba(197,150,58,.85); }
.sh-info h1 { font-family:'Playfair Display',Georgia,serif; color:var(--white); font-size:clamp(22px,3vw,38px); font-weight:700; margin-bottom:12px; text-align:left; }
.sh-desc { font-size:15px; color:rgba(255,255,255,.65); margin-bottom:18px; line-height:1.75; text-align:left; max-width:620px; }
.sh-stats { display:flex; align-items:center; gap:12px; flex-wrap:wrap; font-size:14px; color:rgba(255,255,255,.75); }
.sh-stats b { color:var(--gold-light); }
.sh-dot { color:rgba(255,255,255,.25); }
.sp-page { background:var(--cream); padding:40px 0 72px; }
.sp-layout { display:grid; grid-template-columns:1fr 280px; gap:24px; align-items:start; }
.sp-topics-wrap { background:var(--white); border:1.5px solid var(--border); border-radius:var(--radius-lg); padding:18px 20px; margin-bottom:16px; }
.sp-topics-label { font-size:12px; font-weight:700; color:var(--text-muted); letter-spacing:.06em; text-transform:uppercase; margin-bottom:10px; }
.sp-topics { display:flex; gap:8px; flex-wrap:wrap; }
.sp-topic-chip { font-size:12px; font-weight:600; padding:5px 12px; background:var(--cream); border:1.5px solid var(--border); color:var(--navy); border-radius:100px; }
.sp-topic-chip b { color:var(--gold-dark); margin-left:4px; }
.sp-filter-bar { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:20px; }
.sp-filter-btn { font-size:13px; font-weight:600; padding:8px 16px; border-radius:100px; border:1.5px solid var(--border); background:var(--white); color:var(--text-muted); cursor:pointer; transition:all .18s; font-family:'Plus Jakarta Sans',system-ui,sans-serif; }
.sp-filter-btn:hover { border-color:var(--navy); color:var(--navy); }
.sp-filter-btn.active { background:var(--navy); color:var(--white); border-color:var(--navy); }
.sp-mcq-list { display:flex; flex-direction:column; gap:0; }
.sp-mcq-card { background:var(--white); border-left:1.5px solid var(--border); border-right:1.5px solid var(--border); border-top:1.5px solid var(--border); border-bottom:none; padding:22px 24px; }
.sp-mcq-card:first-child { border-radius:var(--radius-lg) var(--radius-lg) 0 0; }
.sp-mcq-card:last-child  { border-bottom:1.5px solid var(--border); border-radius:0 0 var(--radius-lg) var(--radius-lg); }
.sp-mcq-card+.sp-mcq-card { border-top:1px solid var(--border); }
.sp-mcq-card.sp-answered { background:rgba(11,29,58,.02); }
.sp-mcq-hdr { display:flex; align-items:center; gap:10px; margin-bottom:12px; flex-wrap:wrap; }
.sp-mcq-num { font-size:11px; font-weight:800; letter-spacing:.06em; background:var(--navy); color:var(--gold-light); padding:4px 10px; border-radius:5px; }
.sp-mcq-source { font-size:11px; font-weight:700; padding:3px 9px; background:rgba(197,150,58,.1); border:1px solid rgba(197,150,58,.25); color:var(--gold-dark); border-radius:5px; text-decoration:none; }
.sp-mcq-source:hover { background:rgba(197,150,58,.2); }
.sp-mcq-topic { font-size:11px; color:var(--text-muted); font-weight:500; }
.sp-mcq-text { font-size:15px; font-weight:600; color:var(--navy); line-height:1.6; margin-bottom:16px; text-align:left; }
.sp-opts { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.sp-opt { display:flex; align-items:stretch; border-radius:var(--radius); overflow:hidden; border:2px solid var(--border); cursor:pointer; transition:all .18s; background:var(--white); text-align:left; width:100%; font-family:'Plus Jakarta Sans',system-ui,sans-serif; }
.sp-opt:hover:not([disabled]) { border-color:var(--navy); box-shadow:0 2px 10px rgba(11,29,58,.1); }
.sp-opt[disabled] { cursor:default; }
.sp-opt-key { display:flex; align-items:center; justify-content:center; min-width:44px; background:var(--cream); border-right:2px solid var(--border); font-size:14px; font-weight:800; color:var(--navy); flex-shrink:0; padding:12px 10px; transition:all .18s; }
.sp-opt-val { font-size:14px; font-weight:500; color:var(--text-body); padding:12px 14px; line-height:1.45; flex:1; display:flex; align-items:center; }
.sp-opt-sel { border-color:var(--navy) !important; }
.sp-opt-sel .sp-opt-key { background:var(--navy); border-right-color:var(--navy); color:var(--gold-light); }
.sp-opt-sel .sp-opt-val { color:var(--navy); font-weight:600; }
.sp-opt-ok { border-color:#1A7A40 !important; }
.sp-opt-ok .sp-opt-key { background:#1A7A40; border-right-color:#1A7A40; color:white; }
.sp-opt-ok .sp-opt-val { color:#1A7A40; font-weight:600; }
.sp-opt-no { border-color:#dc2626 !important; }
.sp-opt-no .sp-opt-key { background:#dc2626; border-right-color:#dc2626; color:white; }
.sp-opt-no .sp-opt-val { color:#dc2626; font-weight:600; }
.sp-answer { background:var(--cream); border-radius:var(--radius); padding:14px 16px; margin-top:14px; display:flex; flex-direction:column; gap:10px; }
.sp-ans-label { font-size:12px; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:.06em; }
.sp-ans-val { font-size:15px; font-weight:700; color:#1A7A40; }
.sp-explanation { display:flex; gap:10px; background:rgba(197,150,58,.08); border:1px solid rgba(197,150,58,.2); border-radius:var(--radius); padding:14px; }
.sp-exp-icon { font-size:20px; flex-shrink:0; }
.sp-explanation p { font-size:14px; color:var(--text-body); line-height:1.7; text-align:left; margin:0; }
.sp-full-paper-link { font-size:13px; font-weight:600; color:var(--navy); text-decoration:none; border-bottom:1px solid var(--border); padding-bottom:1px; align-self:flex-start; }
.sp-full-paper-link:hover { color:var(--gold-dark); }
.sp-load-more-wrap { text-align:center; padding:28px 0; }
.sp-btn-load { font-size:15px; font-weight:600; padding:13px 32px; border-radius:var(--radius); border:1.5px solid var(--navy); background:var(--white); color:var(--navy); cursor:pointer; transition:all .2s; font-family:'Plus Jakarta Sans',system-ui,sans-serif; }
.sp-btn-load:hover { background:var(--navy); color:var(--white); }
.sp-empty { background:var(--white); border:1.5px solid var(--border); border-radius:var(--radius-xl); padding:60px 40px; text-align:center; }
.sp-empty-icon { font-size:52px; margin-bottom:16px; }
.sp-empty h2 { font-family:'Playfair Display',Georgia,serif; font-size:24px; color:var(--navy); margin-bottom:10px; text-align:center; }
.sp-empty p { color:var(--text-muted); font-size:15px; text-align:center; max-width:400px; margin:0 auto; }
.sp-btn-gold { display:inline-flex; align-items:center; justify-content:center; gap:8px; background:var(--gold); color:var(--navy); border:2px solid var(--gold); font-family:'Plus Jakarta Sans',system-ui,sans-serif; font-size:15px; font-weight:700; padding:13px 28px; border-radius:var(--radius); cursor:pointer; transition:all .22s; white-space:nowrap; text-decoration:none; }
.sp-btn-gold:hover { background:var(--gold-light); border-color:var(--gold-light); }
.sp-sidebar { display:flex; flex-direction:column; gap:18px; }
.sp-sb-card { background:var(--white); border:1.5px solid var(--border); border-radius:var(--radius-lg); padding:22px 24px; }
.sp-sb-card--cta { background:var(--navy); border-color:var(--navy); text-align:center; }
.sp-sb-card--cta .sp-sb-cta-icon { font-size:32px; margin-bottom:10px; }
.sp-sb-card--cta h3 { font-family:'Playfair Display',Georgia,serif; font-size:17px; color:var(--white); margin-bottom:8px; text-align:center; }
.sp-sb-card--cta p { font-size:13px; color:rgba(255,255,255,.6); margin-bottom:16px; text-align:center; }
.sp-sb-title { font-family:'Playfair Display',Georgia,serif; font-size:16px; font-weight:700; color:var(--navy); margin-bottom:16px; text-align:left; }
.sp-sb-papers { display:flex; flex-direction:column; gap:10px; }
.sp-sb-paper { background:var(--cream); border:1px solid var(--border); border-radius:var(--radius); padding:12px 14px; text-decoration:none; transition:all .18s; display:block; }
.sp-sb-paper:hover { border-color:var(--navy); background:var(--white); }
.sp-sbp-top { display:flex; justify-content:space-between; align-items:center; margin-bottom:4px; }
.sp-sbp-dept { font-size:11px; font-weight:800; padding:2px 8px; background:var(--navy); color:var(--gold-light); border-radius:4px; }
.sp-sbp-year { font-size:11px; font-weight:700; color:var(--text-muted); }
.sp-sbp-title { font-size:13px; font-weight:600; color:var(--navy); }
.sp-sb-links { display:flex; flex-direction:column; gap:8px; }
.sp-sb-link { display:flex; justify-content:space-between; align-items:center; padding:10px 12px; background:var(--cream); border:1px solid var(--border); border-radius:8px; text-decoration:none; font-size:13px; font-weight:600; color:var(--navy); transition:all .18s; }
.sp-sb-link:hover { background:var(--cream-dark); border-color:var(--navy); }
.sp-sb-link--all { background:transparent; border-color:var(--navy); }
@media (max-width:960px) { .sp-layout { grid-template-columns:1fr; } .sp-sidebar { display:grid; grid-template-columns:1fr 1fr; gap:16px; } }
@media (max-width:640px) { .sh-hero-inner { flex-direction:column; gap:16px; } .sh-icon { width:60px; height:60px; font-size:30px; } .sp-sidebar { grid-template-columns:1fr; } .sp-opts { grid-template-columns:1fr; } }
</style>

<script>
document.addEventListener('click', (e) => {
  const opt = e.target.closest('.sp-opt');
  if (!opt || opt.disabled) return;
  const idx     = opt.dataset.q;
  const chosen  = opt.dataset.k;
  const correct = opt.dataset.correct;
  const wrap    = document.getElementById(`so-${idx}`);
  const ans     = document.getElementById(`sa-${idx}`);
  const card    = opt.closest('.sp-mcq-card');
  if (!wrap || !ans) return;
  wrap.querySelectorAll('.sp-opt').forEach(b => {
    b.setAttribute('disabled','');
    const k = b.dataset.k;
    b.classList.remove('sp-opt-sel');
    if (k === correct)               b.classList.add('sp-opt-ok');
    else if (k === chosen)           b.classList.add('sp-opt-no');
  });
  ans.hidden = false;
  card?.classList.add('sp-answered');
});

const filterBtns = document.querySelectorAll('.sp-filter-btn');
const cards = document.querySelectorAll('.sp-mcq-card');
filterBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    filterBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const f = btn.dataset.filter;
    cards.forEach(c => { c.style.display = (f === 'all' || c.dataset.type === f) ? '' : 'none'; });
  });
});

const BATCH = 20;
let shown = Math.min(BATCH, cards.length);
if (cards.length > BATCH) {
  cards.forEach((c, i) => { if (i >= BATCH) c.style.display = 'none'; });
  const wrap = document.getElementById('sp-load-more');
  if (wrap) wrap.style.display = '';
} else {
  const wrap = document.getElementById('sp-load-more');
  if (wrap) wrap.style.display = 'none';
}
document.getElementById('sp-load-btn')?.addEventListener('click', () => {
  const hidden = [...cards].filter(c => c.style.display === 'none');
  hidden.slice(0, BATCH).forEach(c => { c.style.display = ''; });
  shown = Math.min(shown + BATCH, cards.length);
  if (shown >= cards.length) {
    const wrap = document.getElementById('sp-load-more');
    if (wrap) wrap.style.display = 'none';
  }
});
</script>

</BaseLayout>