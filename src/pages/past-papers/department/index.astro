---
// src/pages/past-papers/department/index.astro
// All Departments page — auto-built from src/data/departments.ts
// Add a department there → it appears here automatically.

import BaseLayout from '../../../layouts/BaseLayout.astro';
import { DEPARTMENTS, CATEGORIES, getDeptsByCategory } from '../../../data/departments';
import { getCollection } from 'astro:content';

// Count papers per department from JSON files
const allPapers = await getCollection('past-papers');
const paperCount: Record<string, number> = {};
allPapers.forEach(p => {
  const slug = p.data.deptSlug;
  paperCount[slug] = (paperCount[slug] || 0) + 1;
});

const title       = "All PPSC Departments — Past Papers by Department | GK360.pk";
const description = "Browse PPSC past papers for all government departments — Police, Tehsildar, Education, Finance, ASF, PERA and 40+ more. Solved papers with answer keys.";

const deptSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "PPSC Past Papers — All Departments",
  "description": description,
  "url": "https://gk360.pk/past-papers/department/",
  "provider": { "@type": "Organization", "name": "GK360.pk" }
});
---

<BaseLayout
  title={title}
  description={description}
  keywords="PPSC departments, PPSC past papers by department, Punjab Police papers, Tehsildar papers, Education department papers, all PPSC departments"
  schema={deptSchema}
>

<!-- BREADCRUMB -->
<nav class="bc-nav" aria-label="Breadcrumb">
  <div class="container">
    <ol class="bc-ol">
      <li><a href="/">Home</a></li><li aria-hidden="true">›</li>
      <li><a href="/past-papers/">Past Papers</a></li><li aria-hidden="true">›</li>
      <li class="bc-current">All Departments</li>
    </ol>
  </div>
</nav>

<!-- PAGE HEADER -->
<div class="depts-hero">
  <div class="container">
    <div class="depts-hero-inner">
      <p class="label label-light">Browse by Department</p>
      <h1>All PPSC Exam Departments</h1>
      <p class="depts-hero-sub">Select the government department you're preparing for. Access all past papers, MCQs, and study material in one place.</p>

      <!-- SEARCH BAR -->
      <div class="dept-search-wrap">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          type="search"
          id="dept-search"
          placeholder="Search departments — Police, Education, Finance…"
          aria-label="Search departments"
          autocomplete="off"
        />
      </div>

      <!-- STATS ROW -->
      <div class="depts-stats">
        <div class="ds-item"><span class="ds-num">{DEPARTMENTS.filter(d => d.active).length}+</span><span class="ds-label">Departments</span></div>
        <div class="ds-sep"></div>
        <div class="ds-item"><span class="ds-num">{allPapers.length}+</span><span class="ds-label">Past Papers</span></div>
        <div class="ds-sep"></div>
        <div class="ds-item"><span class="ds-num">{CATEGORIES.length}</span><span class="ds-label">Categories</span></div>
      </div>
    </div>
  </div>
</div>

<!-- DEPARTMENTS BY CATEGORY -->
<main class="depts-main">
  <div class="container">

    <!-- CATEGORY FILTER TABS -->
    <div class="cat-tabs" role="tablist" aria-label="Department categories">
      <button class="cat-tab active" data-cat="all" role="tab" aria-selected="true">All</button>
      {CATEGORIES.map(cat => (
        <button class="cat-tab" data-cat={cat} role="tab" aria-selected="false">{cat}</button>
      ))}
    </div>

    <!-- NO RESULTS MESSAGE -->
    <p class="no-results" id="no-results" hidden>No departments found. Try a different search.</p>

    <!-- DEPARTMENTS GRID — grouped by category -->
    <div id="depts-container">
      {CATEGORIES.map(cat => {
        const depts = getDeptsByCategory(cat);
        return (
          <section class="dept-category-section" data-category={cat} aria-labelledby={`cat-${cat.replace(/\s+/g,'-').toLowerCase()}`}>
            <h2 class="dept-cat-title" id={`cat-${cat.replace(/\s+/g,'-').toLowerCase()}`}>
              {cat}
            </h2>
            <div class="dept-grid">
              {depts.map(dept => {
                const count = paperCount[dept.slug] || 0;
                return (
                  <a
                    href={dept.active ? `/past-papers/department/${dept.slug}/` : '#'}
                    class={`dept-card ${!dept.active ? 'dept-card--soon' : ''}`}
                    data-name={dept.name.toLowerCase()}
                    data-category={cat}
                    aria-label={`${dept.name} — ${count} past papers`}
                  >
                    <span class="dc-icon" aria-hidden="true">{dept.icon}</span>
                    <div class="dc-info">
                      <span class="dc-name">{dept.short}</span>
                      <span class="dc-count">
                        {count > 0 ? `${count} paper${count > 1 ? 's' : ''}` : 'Coming soon'}
                      </span>
                    </div>
                    {count > 0 && <span class="dc-arrow" aria-hidden="true">→</span>}
                    {!dept.active && <span class="dc-soon-badge">Soon</span>}
                  </a>
                );
              })}
            </div>
          </section>
        );
      })}
    </div>

  </div>
</main>

<style is:global>
/* ── HERO ── */
.depts-hero { background: var(--navy); padding: 72px 24px 80px; position: relative; overflow: hidden; }
.depts-hero::before { content:''; position:absolute; inset:0; background-image: linear-gradient(rgba(197,150,58,0.045) 1px,transparent 1px), linear-gradient(90deg, rgba(197,150,58,0.045) 1px,transparent 1px); background-size:64px 64px; pointer-events:none; }
.depts-hero-inner { position:relative; z-index:1; text-align:center; max-width:700px; margin:0 auto; }
.depts-hero .label { color: rgba(197,150,58,0.85); }
.depts-hero h1 { font-family:'Playfair Display',Georgia,serif; color:var(--white); font-size:clamp(28px,4vw,48px); font-weight:700; margin-bottom:14px; text-align:center; }
.depts-hero-sub { font-size:16px; color:rgba(255,255,255,0.65); margin-bottom:32px; line-height:1.75; text-align:center; }

/* Search */
.dept-search-wrap { display:flex; align-items:center; gap:12px; background:rgba(255,255,255,0.09); border:1px solid rgba(255,255,255,0.16); border-radius:12px; padding:12px 20px; max-width:520px; margin:0 auto 36px; transition:border-color .2s; }
.dept-search-wrap:focus-within { border-color:rgba(197,150,58,0.5); }
.dept-search-wrap svg { color:rgba(255,255,255,0.5); flex-shrink:0; }
.dept-search-wrap input { flex:1; background:none; border:none; outline:none; color:white; font-size:15px; font-family:'Plus Jakarta Sans',system-ui,sans-serif; }
.dept-search-wrap input::placeholder { color:rgba(255,255,255,0.4); }

/* Stats */
.depts-stats { display:flex; align-items:center; justify-content:center; gap:0; flex-wrap:wrap; }
.ds-item { text-align:center; padding:0 28px; }
.ds-num  { display:block; font-family:'Playfair Display',Georgia,serif; font-size:32px; font-weight:700; color:var(--gold-light); line-height:1; }
.ds-label { display:block; font-size:11px; color:rgba(255,255,255,0.5); letter-spacing:.08em; text-transform:uppercase; margin-top:4px; }
.ds-sep { width:1px; height:40px; background:rgba(255,255,255,0.12); }

/* ── MAIN CONTENT ── */
.depts-main { background:var(--cream); padding:52px 0 80px; }

/* Category tabs */
.cat-tabs { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:40px; }
.cat-tab { font-size:13px; font-weight:600; padding:8px 16px; border-radius:100px; border:1.5px solid var(--border); background:var(--white); color:var(--text-muted); cursor:pointer; transition:all .18s; font-family:'Plus Jakarta Sans',system-ui,sans-serif; }
.cat-tab:hover { border-color:var(--navy); color:var(--navy); }
.cat-tab.active { background:var(--navy); color:var(--white); border-color:var(--navy); }

/* No results */
.no-results { text-align:center; padding:60px 20px; font-size:16px; color:var(--text-muted); }

/* Category section */
.dept-category-section { margin-bottom:48px; }
.dept-cat-title { font-family:'Playfair Display',Georgia,serif; font-size:22px; font-weight:700; color:var(--navy); margin-bottom:20px; padding-bottom:12px; border-bottom:2px solid var(--border); text-align:left; }

/* Department cards grid */
.dept-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; }

.dept-card {
  background:var(--white);
  border:1.5px solid var(--border);
  border-radius:var(--radius-lg);
  padding:18px 16px;
  text-decoration:none;
  display:flex;
  align-items:center;
  gap:12px;
  transition:all .22s;
  position:relative;
  overflow:hidden;
}
.dept-card::before { content:''; position:absolute; left:0; top:0; bottom:0; width:3px; background:var(--gold); transform:scaleY(0); transform-origin:bottom; transition:transform .25s; }
.dept-card:hover::before { transform:scaleY(1); }
.dept-card:hover { border-color:var(--border-dark); box-shadow:var(--shadow-md); transform:translateY(-2px); }
.dept-card--soon { opacity:.65; cursor:default; }
.dept-card--soon:hover { transform:none; box-shadow:none; border-color:var(--border); }
.dept-card--soon::before { display:none; }

.dc-icon { font-size:26px; flex-shrink:0; width:44px; height:44px; background:var(--cream); border-radius:10px; display:flex; align-items:center; justify-content:center; }
.dc-info { flex:1; min-width:0; }
.dc-name  { display:block; font-size:13px; font-weight:700; color:var(--navy); line-height:1.4; margin-bottom:3px; }
.dc-count { display:block; font-size:11px; color:var(--text-muted); font-weight:500; }
.dc-arrow { font-size:16px; color:var(--text-light); flex-shrink:0; transition:transform .18s; }
.dept-card:hover .dc-arrow { transform:translateX(3px); color:var(--navy); }
.dc-soon-badge { position:absolute; top:10px; right:10px; font-size:10px; font-weight:700; padding:2px 7px; background:var(--cream-dark); color:var(--text-muted); border-radius:4px; letter-spacing:.04em; }

/* Breadcrumb */
.bc-nav { background: var(--cream); border-bottom: 1px solid var(--border); padding: 10px 0; }
.bc-ol  { display:flex; align-items:center; gap:7px; flex-wrap:wrap; list-style:none; font-size:13px; color:var(--text-muted); }
.bc-ol a { color:var(--text-muted); transition:color .2s; }
.bc-ol a:hover { color:var(--navy); }
.bc-current { color:var(--navy); font-weight:600; }

/* Responsive */
@media (max-width:1100px) { .dept-grid { grid-template-columns:repeat(3,1fr); } }
@media (max-width:768px)  { .dept-grid { grid-template-columns:repeat(2,1fr); } .cat-tabs { gap:6px; } }
@media (max-width:480px)  {
  .dept-grid { grid-template-columns:1fr; }
  .depts-stats { gap:0; flex-direction:column; }
  .ds-sep { width:80px; height:1px; }
  .ds-item { padding:10px 0; }
}
</style>

<script>
// ── SEARCH + FILTER ───────────────────────────────────────────────
const searchInput = document.getElementById('dept-search') as HTMLInputElement;
const tabs        = document.querySelectorAll('.cat-tab');
const cards       = document.querySelectorAll('.dept-card') as NodeListOf<HTMLElement>;
const sections    = document.querySelectorAll('.dept-category-section') as NodeListOf<HTMLElement>;
const noResults   = document.getElementById('no-results') as HTMLElement;

let activeCategory = 'all';
let searchQuery    = '';

function applyFilter() {
  let visible = 0;

  // Show/hide category sections
  sections.forEach(sec => {
    const cat = sec.dataset.category || '';
    const showCat = activeCategory === 'all' || cat === activeCategory;

    // Check cards within this section
    let secVisible = 0;
    sec.querySelectorAll('.dept-card').forEach((card: Element) => {
      const el   = card as HTMLElement;
      const name = el.dataset.name || '';
      const matchSearch = !searchQuery || name.includes(searchQuery);
      const matchCat    = activeCategory === 'all' || (el.dataset.category || '') === activeCategory;
      const show = matchSearch && matchCat;
      el.style.display = show ? '' : 'none';
      if (show) secVisible++;
    });

    sec.style.display = (showCat && secVisible > 0) ? '' : 'none';
    visible += secVisible;
  });

  noResults.hidden = visible > 0;
}

// Tab click
tabs.forEach(tab => {
  tab.addEventListener('click', () => {
    tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected','false'); });
    tab.classList.add('active');
    tab.setAttribute('aria-selected','true');
    activeCategory = (tab as HTMLElement).dataset.cat || 'all';
    applyFilter();
  });
});

// Search input
searchInput?.addEventListener('input', () => {
  searchQuery = searchInput.value.toLowerCase().trim();
  applyFilter();
});
</script>

</BaseLayout>
