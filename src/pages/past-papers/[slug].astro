---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const papers = await getCollection('past-papers');
  return papers.map(entry => ({
    params: { slug: entry.data.slug },
    props:  { paper: entry.data },
  }));
}

const { paper } = Astro.props;

// Count static vs dynamic for summary cards
const staticCount  = paper.questions.filter((q: any) => q.type === 'static').length;
const dynamicCount = paper.questions.filter((q: any) => q.type === 'dynamic').length;

const paperSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Quiz",
  "name": paper.titleFull,
  "description": paper.seoDescription,
  "educationalLevel": "professional",
  "datePublished": paper.date,
  "provider": { "@type": "Organization", "name": "GK360.pk", "url": "https://gk360.pk" }
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",        "item": "https://gk360.pk/" },
    { "@type": "ListItem", "position": 2, "name": "Past Papers", "item": "https://gk360.pk/past-papers/" },
    { "@type": "ListItem", "position": 3, "name": paper.departmentShort, "item": `https://gk360.pk/past-papers/department/${paper.deptSlug}/` },
    { "@type": "ListItem", "position": 4, "name": paper.title,   "item": `https://gk360.pk/past-papers/${paper.slug}/` }
  ]
});

const shareUrl  = `https://gk360.pk/past-papers/${paper.slug}/`;
const shareText = encodeURIComponent(`${paper.titleFull} — Attempt this solved paper on GK360.pk`);

const SUBJECT_LABELS: Record<string, string> = {
  'pera-law':          'PERA Law',
  'english':           'English',
  'basic-mathematics': 'Mathematics',
  'pakistan-studies':  'Pakistan Studies',
  'general-science':   'General Science',
  'computer-basics':   'Computer / IT',
  'current-affairs':   'Current Affairs',
  'geography-maps':    'Geography & Maps',
  'general-knowledge': 'General Knowledge',
};
---

<BaseLayout
  title={paper.seoTitle}
  description={paper.seoDescription}
  keywords={`${paper.title}, ${paper.department}, PPSC past paper ${paper.year}, solved past paper MCQs`}
  schema={`[${paperSchema},${breadcrumbSchema}]`}
>

<!-- ══ BREADCRUMB ══════════════════════════════════════════ -->
<nav class="bc-nav" aria-label="Breadcrumb">
  <div class="container">
    <ol class="bc-ol">
      <li><a href="/">Home</a></li><li aria-hidden="true">›</li>
      <li><a href="/past-papers/">Past Papers</a></li><li aria-hidden="true">›</li>
      <li><a href={`/past-papers/department/${paper.deptSlug}/`}>{paper.departmentShort}</a></li><li aria-hidden="true">›</li>
      <li class="bc-current">{paper.title} {paper.year}</li>
    </ol>
  </div>
</nav>

<div class="pp-wrap">
  <div class="container">
    <div class="pp-grid">

      <!-- ══ MAIN COLUMN ══════════════════════════════════ -->
      <main class="pp-main">

        <!-- ── PAPER HEADER ── -->
        <div class="ph-card">
          <div class="ph-top">
            <div class="ph-badges">
              <span class="ph-dept">{paper.departmentShort}</span>
              <span class="ph-year">{paper.year}</span>
              {paper.solved && <span class="ph-solved">✅ Solved</span>}
            </div>
            <button class="ph-share-btn" id="js-share-btn" aria-label="Share" aria-expanded="false">
              <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
              Share
            </button>
          </div>

          <h1 class="ph-title">{paper.titleFull}</h1>

          <div class="ph-meta">
            <span>📄 <b>{paper.totalQuestions}</b> MCQs</span>
            <span class="ph-dot">·</span>
            <span>⏱ <b>{paper.timeMinutes}</b> min</span>
            <span class="ph-dot">·</span>
            <span>📅 {new Date(paper.date).toLocaleDateString('en-PK',{day:'numeric',month:'long',year:'numeric'})}</span>
            <span class="ph-dot">·</span>
            <span>🏛️ {paper.conductedBy}</span>
          </div>

          <!-- Share panel -->
          <div class="ph-share-panel" id="js-share-panel" hidden>
            <p class="ph-share-label">Share this paper with friends:</p>
            <div class="ph-share-btns">
              <a href={`https://api.whatsapp.com/send?text=${shareText}%0A${encodeURIComponent(shareUrl)}`}
                 target="_blank" rel="noopener noreferrer" class="shr-wa">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z M12 0C5.373 0 0 5.373 0 12c0 2.1.546 4.07 1.5 5.78L0 24l6.375-1.5A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
                </svg>
                WhatsApp
              </a>
              <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`}
                 target="_blank" rel="noopener noreferrer" class="shr-fb">📘 Facebook</a>
              <a href={`https://twitter.com/intent/tweet?text=${shareText}&url=${encodeURIComponent(shareUrl)}`}
                 target="_blank" rel="noopener noreferrer" class="shr-tw">𝕏 Twitter</a>
              <button class="shr-copy" id="js-copy-btn">🔗 Copy Link</button>
            </div>
            <p class="shr-copied" id="js-copy-confirm" hidden>✅ Link copied!</p>
          </div>

          <!-- CTA buttons -->
          <div class="ph-cta">
            <button class="btn-gold" id="js-start-timer">⏱ Attempt with Timer</button>
            <button class="btn-navy" id="js-start-view">👁 View Paper</button>
          </div>
        </div>

        <!-- ── STATS CARDS ── -->
        <div class="stats-row">
          <!-- Subject breakdown -->
          {paper.subjectBreakdown.map((s: any) => (
            <a href={`/subjects/${s.subject}/`} class="stat-card">
              <div class="sc-top">
                <span class="sc-name">{s.label}</span>
                <span class="sc-count">{s.count}</span>
              </div>
              <div class="sc-track"><div class="sc-fill" style={`width:${s.percentage}%`}></div></div>
              <span class="sc-pct">{s.percentage}%</span>
            </a>
          ))}
          <!-- Static / Dynamic summary cards -->
          <div class="stat-card stat-card--static">
            <div class="sc-top">
              <span class="sc-name">📌 Memorise (Static)</span>
              <span class="sc-count">{staticCount}</span>
            </div>
            <div class="sc-track"><div class="sc-fill sc-fill--green" style={`width:${Math.round(staticCount/paper.totalQuestions*100)}%`}></div></div>
            <span class="sc-pct sc-pct--green">{Math.round(staticCount/paper.totalQuestions*100)}% of paper</span>
          </div>
          <div class="stat-card stat-card--dynamic">
            <div class="sc-top">
              <span class="sc-name">🔄 Stay Updated (Current)</span>
              <span class="sc-count">{dynamicCount}</span>
            </div>
            <div class="sc-track"><div class="sc-fill sc-fill--orange" style={`width:${Math.round(dynamicCount/paper.totalQuestions*100)}%`}></div></div>
            <span class="sc-pct sc-pct--orange">{Math.round(dynamicCount/paper.totalQuestions*100)}% of paper</span>
          </div>
        </div>

        <!-- ── QUIZ AREA ── -->
        <div class="qa-wrap" id="js-quiz-area">

          <!-- Start screen -->
          <div class="qa-start" id="js-start-screen">
            <div class="qa-start-icon">📋</div>
            <h2>Ready to Attempt?</h2>
            <p>{paper.totalQuestions} questions &nbsp;·&nbsp; {paper.timeMinutes} minutes</p>
            <p class="qa-start-hint">Timed mode simulates real exam conditions. View mode lets you study at your own pace.</p>
            <div class="qa-start-btns">
              <button class="btn-gold" id="js-start-timer-2">⏱ Start with Timer</button>
              <button class="btn-navy" id="js-start-view-2">👁 View Without Timer</button>
            </div>
          </div>

          <!-- Timer bar -->
          <div class="qa-timer" id="js-timer" hidden>
            <div class="qa-timer-left">
              <span class="qa-timer-icon">⏱</span>
              <span class="qa-timer-time" id="js-timer-display">90:00</span>
              <span class="qa-timer-label">remaining</span>
            </div>
            <div class="qa-timer-track"><div class="qa-timer-fill" id="js-timer-fill"></div></div>
            <div class="qa-timer-right">
              <span class="qa-answered-count" id="js-ans-count">0 / {paper.totalQuestions} answered</span>
              <button class="btn-gold btn-sm" id="js-submit-btn">Submit Paper →</button>
            </div>
          </div>

          <!-- Questions (rendered by JS) -->
          <div id="js-questions" hidden></div>

          <!-- Results panel -->
          <div class="qa-results" id="js-results" hidden>
            <div class="qar-ring" id="js-ring">
              <span class="qar-score" id="js-score">0</span>
              <span class="qar-total">/ {paper.totalQuestions}</span>
            </div>
            <h2 class="qar-title" id="js-res-title">Your Result</h2>
            <p class="qar-msg" id="js-res-msg"></p>
            <div class="qar-stats" id="js-res-stats"></div>
            <div class="qar-actions">
              <button class="btn-gold"  id="js-retry-btn">🔄 Try Again</button>
              <button class="btn-navy"  id="js-review-btn">✅ Review Answers</button>
              <a href="/past-papers/"   class="btn-ghost-link">← More Papers</a>
            </div>
          </div>

        </div>
      </main>

      <!-- ══ SIDEBAR ════════════════════════════════════════ -->
      <aside class="pp-sidebar">

        <div class="sb-card">
          <h3 class="sb-title">Paper Details</h3>
          <ul class="sb-list">
            <li><span>Department</span><span>{paper.department}</span></li>
            <li><span>Post</span><span>{paper.post}</span></li>
            <li><span>Year</span><span>{paper.year}</span></li>
            <li><span>Questions</span><span>{paper.totalQuestions}</span></li>
            <li><span>Time</span><span>{paper.timeMinutes} min</span></li>
            <li><span>Conducted By</span><span>{paper.conductedBy}</span></li>
            <li><span>Difficulty</span><span style="text-transform:capitalize">{paper.difficulty}</span></li>
          </ul>
        </div>

        <div class="sb-card">
          <h3 class="sb-title">More Papers</h3>
          <div class="sb-links">
            <a href={`/past-papers/department/${paper.deptSlug}/`} class="sb-link">🏛️ All {paper.departmentShort} Papers <span>→</span></a>
            <a href={`/past-papers/year/${paper.year}/`}          class="sb-link">📅 All {paper.year} Papers <span>→</span></a>
            <a href="/past-papers/"                               class="sb-link">📚 All Past Papers <span>→</span></a>
            <a href="/course/"                                    class="sb-link sb-link--cta">🎯 Join Full Course <span>→</span></a>
          </div>
        </div>

        <div class="sb-card">
          <h3 class="sb-title">Topics</h3>
          <div class="sb-tags">
            {paper.tags.map((t: string) => <span class="sb-tag">{t}</span>)}
          </div>
        </div>

      </aside>
    </div>
  </div>
</div>

<!-- ══ STYLES ══════════════════════════════════════════════ -->
<style is:global>

/* Breadcrumb */
.bc-nav { background: var(--cream); border-bottom: 1px solid var(--border); padding: 10px 0; }
.bc-ol  { display:flex; align-items:center; gap:7px; flex-wrap:wrap; list-style:none; font-size:13px; color:var(--text-muted); }
.bc-ol a { color:var(--text-muted); transition:color .2s; }
.bc-ol a:hover { color:var(--navy); }
.bc-current { color:var(--navy); font-weight:600; }

/* Page wrapper */
.pp-wrap { background:var(--cream); padding:36px 0 72px; min-height:60vh; }
.pp-grid { display:grid; grid-template-columns:1fr 290px; gap:24px; align-items:start; }

/* ── PAPER HEADER ── */
.ph-card { background:var(--white); border:1.5px solid var(--border); border-radius:var(--radius-xl); padding:32px; margin-bottom:20px; }
.ph-top  { display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:14px; flex-wrap:wrap; }
.ph-badges { display:flex; gap:8px; flex-wrap:wrap; align-items:center; }
.ph-dept   { font-size:11px; font-weight:800; letter-spacing:.08em; text-transform:uppercase; padding:5px 12px; background:var(--navy); color:var(--gold-light); border-radius:6px; }
.ph-year   { font-size:12px; font-weight:700; padding:5px 12px; background:var(--cream); border:1.5px solid var(--border); color:var(--navy); border-radius:6px; }
.ph-solved { font-size:12px; font-weight:700; padding:5px 12px; background:rgba(26,122,64,.08); border:1.5px solid rgba(26,122,64,.2); color:#1A7A40; border-radius:6px; }
.ph-share-btn { display:inline-flex; align-items:center; gap:6px; font-size:13px; font-weight:600; color:var(--navy); background:var(--cream); border:1.5px solid var(--border); border-radius:8px; padding:8px 14px; cursor:pointer; transition:all .2s; }
.ph-share-btn:hover { background:var(--cream-dark); border-color:var(--navy); }
.ph-title { font-family:'Playfair Display',Georgia,serif; font-size:clamp(20px,2.6vw,30px); font-weight:700; color:var(--navy); margin-bottom:14px; text-align:left; line-height:1.3; }
.ph-meta  { display:flex; align-items:center; gap:10px; flex-wrap:wrap; font-size:14px; color:var(--text-muted); margin-bottom:22px; }
.ph-dot   { color:var(--border-dark); }

/* Share panel */
.ph-share-panel { background:var(--cream); border:1.5px solid var(--border); border-radius:var(--radius-lg); padding:18px 20px; margin-bottom:20px; }
.ph-share-label { font-size:13px; font-weight:700; color:var(--text-muted); margin-bottom:12px; }
.ph-share-btns  { display:flex; gap:8px; flex-wrap:wrap; }
.shr-wa,.shr-fb,.shr-tw,.shr-copy { display:inline-flex; align-items:center; gap:6px; font-size:13px; font-weight:700; padding:9px 15px; border-radius:8px; text-decoration:none; cursor:pointer; border:1.5px solid transparent; transition:all .2s; font-family:'Plus Jakarta Sans',system-ui,sans-serif; }
.shr-wa   { background:#1A7A40; color:white; border-color:#1A7A40; }
.shr-wa:hover { background:#155f32; }
.shr-fb   { background:#1877F2; color:white; border-color:#1877F2; }
.shr-fb:hover { background:#0d63d0; }
.shr-tw   { background:#000; color:white; border-color:#000; }
.shr-tw:hover { background:#333; }
.shr-copy { background:var(--white); color:var(--navy); border-color:var(--border); }
.shr-copy:hover { background:var(--cream-dark); border-color:var(--navy); }
.shr-copied { font-size:13px; color:#1A7A40; font-weight:600; margin-top:10px; }

/* CTA buttons */
.ph-cta { display:flex; gap:12px; flex-wrap:wrap; }
.btn-gold { display:inline-flex; align-items:center; justify-content:center; gap:8px; background:var(--gold); color:var(--navy); border:2px solid var(--gold); font-family:'Plus Jakarta Sans',system-ui,sans-serif; font-size:15px; font-weight:700; padding:13px 28px; border-radius:var(--radius); cursor:pointer; transition:all .22s; white-space:nowrap; text-decoration:none; }
.btn-gold:hover { background:var(--gold-light); border-color:var(--gold-light); transform:translateY(-1px); box-shadow:0 6px 20px rgba(197,150,58,.3); }
.btn-navy { display:inline-flex; align-items:center; justify-content:center; gap:8px; background:var(--navy); color:var(--white); border:2px solid var(--navy); font-family:'Plus Jakarta Sans',system-ui,sans-serif; font-size:15px; font-weight:600; padding:13px 28px; border-radius:var(--radius); cursor:pointer; transition:all .22s; white-space:nowrap; text-decoration:none; }
.btn-navy:hover { background:var(--navy-light); border-color:var(--navy-light); transform:translateY(-1px); }
.btn-sm { font-size:13px !important; padding:9px 18px !important; }
.btn-ghost-link { display:inline-flex; align-items:center; gap:6px; background:transparent; color:var(--navy); border:1.5px solid var(--border); padding:13px 20px; border-radius:var(--radius); font-size:14px; font-weight:600; font-family:'Plus Jakarta Sans',system-ui,sans-serif; cursor:pointer; text-decoration:none; transition:all .2s; }
.btn-ghost-link:hover { background:var(--cream); border-color:var(--navy); }

/* ── STATS CARDS ROW ── */
.stats-row { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:20px; }
.stat-card { background:var(--white); border:1.5px solid var(--border); border-radius:var(--radius-lg); padding:14px 16px; text-decoration:none; display:block; transition:all .2s; }
.stat-card:hover { border-color:var(--navy); box-shadow:var(--shadow); }
.stat-card--static  { border-left:3px solid #1A7A40; }
.stat-card--dynamic { border-left:3px solid var(--gold); }
.sc-top   { display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; gap:6px; }
.sc-name  { font-size:12px; font-weight:700; color:var(--navy); line-height:1.3; }
.sc-count { font-size:18px; font-weight:800; color:var(--navy); font-family:'Playfair Display',Georgia,serif; flex-shrink:0; }
.sc-track { height:5px; background:var(--cream-dark); border-radius:3px; overflow:hidden; margin-bottom:5px; }
.sc-fill  { height:100%; background:linear-gradient(to right,var(--gold),var(--gold-light)); border-radius:3px; }
.sc-fill--green  { background:linear-gradient(to right,#1A7A40,#22a05a); }
.sc-fill--orange { background:linear-gradient(to right,var(--gold-dark),var(--gold)); }
.sc-pct  { font-size:11px; color:var(--text-muted); font-weight:600; }
.sc-pct--green  { color:#1A7A40; }
.sc-pct--orange { color:var(--gold-dark); }

/* ── START SCREEN ── */
.qa-wrap { }
.qa-start { background:var(--white); border:1.5px solid var(--border); border-radius:var(--radius-xl); padding:56px 40px; text-align:center; }
.qa-start-icon { font-size:60px; margin-bottom:18px; }
.qa-start h2   { font-family:'Playfair Display',Georgia,serif; font-size:28px; color:var(--navy); margin-bottom:8px; text-align:center; }
.qa-start p    { font-size:15px; color:var(--text-muted); text-align:center; }
.qa-start-hint { font-size:13px; color:var(--text-light); margin-top:8px; }
.qa-start-btns { display:flex; gap:12px; justify-content:center; margin-top:28px; flex-wrap:wrap; }

/* ── TIMER BAR ── */
.qa-timer { background:var(--navy); border-radius:var(--radius-lg); padding:14px 20px; margin-bottom:16px; display:flex; align-items:center; gap:14px; flex-wrap:wrap; }
.qa-timer-left  { display:flex; align-items:center; gap:10px; }
.qa-timer-icon  { font-size:20px; }
.qa-timer-time  { font-family:'Playfair Display',Georgia,serif; font-size:28px; font-weight:700; color:var(--gold-light); min-width:70px; }
.qa-timer-label { font-size:11px; color:rgba(255,255,255,.6); text-transform:uppercase; letter-spacing:.06em; }
.qa-timer-track { flex:1; height:8px; background:rgba(255,255,255,.15); border-radius:4px; overflow:hidden; min-width:80px; }
.qa-timer-fill  { height:100%; background:var(--gold); border-radius:4px; transition:width 1s linear, background 1s; width:100%; }
.qa-timer-right { display:flex; align-items:center; gap:14px; flex-wrap:wrap; margin-left:auto; }
.qa-answered-count { font-size:12px; font-weight:600; color:rgba(255,255,255,.7); white-space:nowrap; }

/* ── QUESTION CARDS ── */
/* All questions rendered by JS. Styles here for JS-injected HTML */
.qcard {
  background: var(--white);
  border-left: 1.5px solid var(--border);
  border-right: 1.5px solid var(--border);
  border-top: 1.5px solid var(--border);
  border-bottom: none;
  padding: 26px 28px 22px;
  transition: background .18s;
}
.qcard:first-child { border-radius: var(--radius-lg) var(--radius-lg) 0 0; }
.qcard:last-child  { border-bottom: 1.5px solid var(--border); border-radius: 0 0 var(--radius-lg) var(--radius-lg); }
.qcard:only-child  { border-bottom: 1.5px solid var(--border); border-radius: var(--radius-lg); }
.qcard + .qcard    { border-top: 1px solid var(--border); }
.qcard.q-done      { background:rgba(11,29,58,.02); }
.qcard.q-correct   { background:rgba(26,122,64,.03); border-left-color:#1A7A40; border-right-color:#1A7A40; border-top-color:#1A7A40; }
.qcard.q-wrong     { background:rgba(220,38,38,.03); border-left-color:#dc2626; border-right-color:#dc2626; border-top-color:#dc2626; }
.qcard:last-child.q-correct { border-bottom-color:#1A7A40; }
.qcard:last-child.q-wrong   { border-bottom-color:#dc2626; }

.qhdr { display:flex; align-items:center; gap:10px; margin-bottom:12px; }
.qnum { font-size:11px; font-weight:800; letter-spacing:.06em; background:var(--navy); color:var(--gold-light); padding:4px 10px; border-radius:5px; }
.qsubj { font-size:11px; font-weight:700; padding:3px 8px; background:var(--cream); border:1px solid var(--border); color:var(--text-muted); border-radius:4px; }

.qtext {
  font-size: 16px;
  font-weight: 600;
  color: var(--navy);
  line-height: 1.6;
  margin-bottom: 18px;
  text-align: left;
}

/* OPTIONS GRID — 2 per row, beautiful */
.qopts {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.qopt {
  display: flex;
  align-items: stretch;
  border-radius: var(--radius);
  overflow: hidden;
  border: 2px solid var(--border);
  cursor: pointer;
  transition: all .18s;
  background: var(--white);
  text-align: left;
  width: 100%;
  font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
  position: relative;
}
/* Hover */
.qopt:hover:not([disabled]):not(.qopt-sel):not(.qopt-ok):not(.qopt-no) {
  border-color: var(--navy);
  box-shadow: 0 2px 12px rgba(11,29,58,.1);
}
.qopt[disabled] { cursor: default; }

/* Option letter bubble */
.qopt-key {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 46px;
  background: var(--cream);
  border-right: 2px solid var(--border);
  font-size: 14px;
  font-weight: 800;
  color: var(--navy);
  transition: all .18s;
  flex-shrink: 0;
  padding: 14px 12px;
}

/* Option text */
.qopt-val {
  font-size: 14px;
  font-weight: 500;
  color: var(--text-body);
  padding: 14px 16px;
  line-height: 1.5;
  flex: 1;
  display: flex;
  align-items: center;
}

/* ── SELECTED state ── */
.qopt-sel {
  border-color: var(--navy);
  background: rgba(11,29,58,.04);
}
.qopt-sel .qopt-key {
  background: var(--navy);
  border-right-color: var(--navy);
  color: var(--gold-light);
}
.qopt-sel .qopt-val {
  color: var(--navy);
  font-weight: 600;
}

/* ── CORRECT state (shown after review) ── */
.qopt-ok {
  border-color: #1A7A40;
  background: rgba(26,122,64,.05);
}
.qopt-ok .qopt-key {
  background: #1A7A40;
  border-right-color: #1A7A40;
  color: white;
}
.qopt-ok .qopt-val {
  color: #1A7A40;
  font-weight: 600;
}

/* ── WRONG state ── */
.qopt-no {
  border-color: #dc2626;
  background: rgba(220,38,38,.04);
}
.qopt-no .qopt-key {
  background: #dc2626;
  border-right-color: #dc2626;
  color: white;
}
.qopt-no .qopt-val {
  color: #dc2626;
  font-weight: 600;
}

/* ── RESULTS ── */
.qa-results { background:var(--white); border:1.5px solid var(--border); border-radius:var(--radius-xl); padding:52px 32px; text-align:center; margin-top:16px; }
.qar-ring   { display:inline-flex; align-items:center; justify-content:center; flex-direction:column; background:var(--navy); border-radius:50%; width:128px; height:128px; margin-bottom:22px; }
.qar-score  { font-family:'Playfair Display',Georgia,serif; font-size:42px; font-weight:700; color:var(--gold-light); line-height:1; }
.qar-total  { font-size:14px; color:rgba(255,255,255,.6); }
.qar-title  { font-family:'Playfair Display',Georgia,serif; font-size:28px; color:var(--navy); margin-bottom:10px; text-align:center; }
.qar-msg    { font-size:15px; color:var(--text-muted); margin-bottom:22px; text-align:center; }
.qar-stats  { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; margin-bottom:28px; }
.qar-stat   { font-size:14px; font-weight:700; padding:9px 18px; border-radius:8px; }
.qar-c      { background:rgba(26,122,64,.1); color:#1A7A40; }
.qar-w      { background:rgba(220,38,38,.1); color:#dc2626; }
.qar-s      { background:var(--cream); color:var(--text-muted); }
.qar-p      { background:var(--navy); color:var(--gold-light); }
.qar-actions { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; }

/* ── SIDEBAR ── */
.pp-sidebar { display:flex; flex-direction:column; gap:18px; }
.sb-card { background:var(--white); border:1.5px solid var(--border); border-radius:var(--radius-lg); padding:22px 24px; }
.sb-title { font-family:'Playfair Display',Georgia,serif; font-size:16px; font-weight:700; color:var(--navy); margin-bottom:16px; text-align:left; }
.sb-list  { display:flex; flex-direction:column; gap:0; }
.sb-list li { display:flex; justify-content:space-between; align-items:flex-start; gap:8px; font-size:13px; padding:9px 0; border-bottom:1px solid var(--border); }
.sb-list li:last-child { border-bottom:none; padding-bottom:0; }
.sb-list li span:first-child { color:var(--text-muted); font-weight:500; }
.sb-list li span:last-child  { color:var(--navy); font-weight:600; text-align:right; }
.sb-links { display:flex; flex-direction:column; gap:8px; }
.sb-link  { display:flex; justify-content:space-between; align-items:center; padding:10px 12px; background:var(--cream); border:1px solid var(--border); border-radius:8px; text-decoration:none; font-size:13px; font-weight:600; color:var(--navy); transition:all .18s; }
.sb-link:hover { background:var(--cream-dark); border-color:var(--navy); }
.sb-link--cta  { background:var(--navy); color:var(--gold-light); border-color:var(--navy); }
.sb-link--cta:hover { background:var(--navy-light); }
.sb-tags { display:flex; flex-wrap:wrap; gap:8px; }
.sb-tag  { font-size:11px; font-weight:600; padding:4px 10px; background:var(--cream); border:1.5px solid var(--border); color:var(--text-muted); border-radius:100px; }

/* ── RESPONSIVE ── */
@media (max-width:960px)  { .pp-grid { grid-template-columns:1fr; } .pp-sidebar { order:-1; display:grid; grid-template-columns:1fr 1fr; gap:16px; } .stats-row { grid-template-columns:repeat(2,1fr); } }
@media (max-width:640px)  {
  .pp-grid { grid-template-columns:1fr; }
  .pp-sidebar { grid-template-columns:1fr; }
  .ph-card { padding:20px; }
  .ph-title { font-size:19px; }
  .ph-meta  { font-size:13px; gap:7px; }
  .ph-cta   { flex-direction:column; }
  .ph-cta .btn-gold, .ph-cta .btn-navy { width:100%; }
  .qa-start { padding:40px 20px; }
  .qa-start-btns { flex-direction:column; align-items:center; }
  .qa-timer { gap:10px; }
  .qa-timer-right { margin-left:0; width:100%; justify-content:space-between; }
  .qcard { padding:18px 16px 16px; }
  .qopts { grid-template-columns:1fr; }  /* single column on mobile */
  .qar-actions { flex-direction:column; align-items:center; }
  .qar-actions > * { width:100%; max-width:300px; justify-content:center; }
  .stats-row { grid-template-columns:1fr; }
  .ph-share-btns { flex-direction:column; }
  .ph-share-btns > * { width:100%; justify-content:center; }
}
</style>

<!-- ══ QUIZ ENGINE ════════════════════════════════════════ -->
<script define:vars={{ questions: paper.questions, totalTime: paper.timeMinutes * 60, totalQ: paper.totalQuestions }}>

const SL = {
  'pera-law':'PERA Law','english':'English','basic-mathematics':'Maths',
  'pakistan-studies':'Pak Studies','general-science':'Gen. Science',
  'computer-basics':'Computer/IT','current-affairs':'Current Affairs',
  'geography-maps':'Geography','general-knowledge':'Gen. Knowledge',
};

let ans = {}, timerRef = null, timeLeft = totalTime, timed = false, done = false, answered = 0;

function el(id){ return document.getElementById(id); }

// ── BOOT: wire up all buttons after DOM ready ─────────────
document.addEventListener('DOMContentLoaded', () => {
  // Top header buttons
  el('js-start-timer')  ?.addEventListener('click', () => boot(true));
  el('js-start-view')   ?.addEventListener('click', () => boot(false));
  // Start screen buttons
  el('js-start-timer-2')?.addEventListener('click', () => boot(true));
  el('js-start-view-2') ?.addEventListener('click', () => boot(false));
  // Timer submit
  el('js-submit-btn')   ?.addEventListener('click', () => finish());
  // Results buttons
  el('js-retry-btn')    ?.addEventListener('click', () => boot(timed));
  el('js-review-btn')   ?.addEventListener('click', () => review());
  // Share
  el('js-share-btn')    ?.addEventListener('click', () => {
    const p = el('js-share-panel');
    const b = el('js-share-btn');
    if (!p) return;
    p.hidden = !p.hidden;
    b?.setAttribute('aria-expanded', String(!p.hidden));
  });
  // Copy link
  el('js-copy-btn')?.addEventListener('click', () => {
    const url = window.location.href;
    (navigator.clipboard?.writeText(url) ?? Promise.reject())
      .then(confirmCopy)
      .catch(() => { const t=document.createElement('textarea'); t.value=url; document.body.appendChild(t); t.select(); document.execCommand('copy'); document.body.removeChild(t); confirmCopy(); });
  });
  // Question option delegation — single listener on document
  document.addEventListener('click', (e) => {
    const opt = e.target.closest('.qopt');
    if (!opt || opt.disabled || done) return;
    const qNo = parseInt(opt.dataset.q);
    const key  = opt.dataset.k;
    if (!qNo || !key) return;
    select(qNo, key, opt.closest('.qcard'));
  });
});

function confirmCopy() {
  const c = el('js-copy-confirm');
  if (c) { c.hidden=false; setTimeout(()=>c.hidden=true, 3000); }
}

// ── BOOT ─────────────────────────────────────────────────
function boot(timedMode) {
  timed = timedMode; done = false; ans = {}; answered = 0;
  timeLeft = totalTime;
  if (timerRef) clearInterval(timerRef);

  el('js-start-screen').hidden = true;
  el('js-questions').hidden    = false;
  el('js-results').hidden      = true;
  el('js-timer').hidden        = !timedMode;

  if (timedMode) { tick(); timerRef = setInterval(tick, 1000); }

  buildQs(false);
  updateAnsweredCount();
  el('js-quiz-area')?.scrollIntoView({ behavior:'smooth', block:'start' });
}

// ── BUILD QUESTIONS ───────────────────────────────────────
function buildQs(showAns) {
  const wrap = el('js-questions');
  if (!wrap) return;
  wrap.innerHTML = questions.map(q => {
    const ua = ans[q.no];
    let cardCls = 'qcard';
    if (showAns && ua) cardCls += ua===q.correct ? ' q-correct' : ' q-wrong';
    else if (ua) cardCls += ' q-done';

    const opts = Object.entries(q.options).map(([k,v]) => {
      let cls = 'qopt';
      if (showAns) {
        if (k===q.correct) cls+=' qopt-ok';
        else if (k===ua)   cls+=' qopt-no';
      } else if (k===ua) cls+=' qopt-sel';

      const tick = showAns && k===q.correct ? ' ✅' : (showAns && k===ua && k!==q.correct ? ' ❌' : '');
      return `<button class="${cls}" data-q="${q.no}" data-k="${k}" ${(showAns||done)?'disabled':''} aria-label="Option ${k}">
        <span class="qopt-key">${k}</span>
        <span class="qopt-val">${v}${tick}</span>
      </button>`;
    }).join('');

    return `<div class="${cardCls}" id="qc${q.no}">
      <div class="qhdr">
        <span class="qnum">Q.${q.no}</span>
        <span class="qsubj">${SL[q.subject]||q.subject}</span>
      </div>
      <p class="qtext">${q.question}</p>
      <div class="qopts">${opts}</div>
    </div>`;
  }).join('');
}

// ── SELECT ────────────────────────────────────────────────
function select(qNo, key, card) {
  const wasNew = !ans[qNo];
  ans[qNo] = key;
  if (wasNew) { answered++; updateAnsweredCount(); }

  // Update card class
  if (card) { card.className = card.className.replace(/\bq-done\b/,''); card.classList.add('q-done'); }

  // Update buttons within this card only — no re-render
  card?.querySelectorAll('.qopt').forEach(btn => {
    btn.classList.remove('qopt-sel');
    if (btn.dataset.k === key) btn.classList.add('qopt-sel');
  });
}

function updateAnsweredCount() {
  const c = el('js-ans-count');
  if (c) c.textContent = `${answered} / ${totalQ} answered`;
}

// ── TIMER ─────────────────────────────────────────────────
function tick() {
  timeLeft = Math.max(0, timeLeft-1);
  const m = String(Math.floor(timeLeft/60)).padStart(2,'0');
  const s = String(timeLeft%60).padStart(2,'0');
  const td = el('js-timer-display'); if (td) td.textContent=`${m}:${s}`;
  const tf = el('js-timer-fill');
  if (tf) {
    const pct=(timeLeft/totalTime)*100;
    tf.style.width=`${pct}%`;
    tf.style.background = pct>50?'var(--gold)':pct>20?'#f97316':'#dc2626';
  }
  if (timeLeft<=0) { clearInterval(timerRef); finish(true); }
}

// ── FINISH ────────────────────────────────────────────────
function finish(timeUp=false) {
  if (timerRef) clearInterval(timerRef);
  done = true;
  let c=0, w=0, sk=0;
  questions.forEach(q => {
    const a=ans[q.no]; if (!a) sk++; else if (a===q.correct) c++; else w++;
  });
  const pct=Math.round((c/totalQ)*100);
  const msgs=[
    {min:80,title:'Excellent! 🎉',msg:'Outstanding performance. You are fully exam-ready!'},
    {min:60,title:'Good Result! 👍',msg:'Solid score. A bit more practice and you\'ll nail it.'},
    {min:40,title:'Keep Going! 📚',msg:'Focus on your weak subjects and attempt again.'},
    {min:0, title:'Keep Trying! 💪',msg:'Don\'t give up — review the answer key and try again.'},
  ];
  const lv=msgs.find(m=>pct>=m.min);
  el('js-timer').hidden   = true;
  el('js-results').hidden = false;
  el('js-score').textContent = c;
  el('js-res-title').textContent = timeUp?'⏱ Time Up!':lv.title;
  el('js-res-msg').textContent   = lv.msg;
  el('js-res-stats').innerHTML = `
    <span class="qar-stat qar-c">✅ ${c} Correct</span>
    <span class="qar-stat qar-w">❌ ${w} Wrong</span>
    <span class="qar-stat qar-s">⏭ ${sk} Skipped</span>
    <span class="qar-stat qar-p">${pct}%</span>`;
  // Color the score ring
  const ring=el('js-ring');
  if (ring) ring.style.background = pct>=60?'#1A3A2A':pct>=40?'#3A2A0A':'#3A0A0A';
  el('js-results')?.scrollIntoView({behavior:'smooth',block:'start'});
}

// ── REVIEW ────────────────────────────────────────────────
function review() {
  el('js-results').hidden = true;
  buildQs(true);
  el('js-questions')?.scrollIntoView({behavior:'smooth'});
}
</script>

</BaseLayout>
